Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "renderSoln", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"renderSoln", "[", 
    RowBox[{"nsoln_", ",", "tn_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"pr", "=", "1.25"}], ",", 
       RowBox[{"e1", "=", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], ",", 
       RowBox[{"e2", "=", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], ",", 
       RowBox[{"e3", "=", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", 
       RowBox[{"squish", "=", "0.0001"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"prl", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "pr"}], ",", "pr"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "pr"}], ",", "pr"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "pr"}], ",", "pr"}], "}"}]}], "}"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Show", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Graphics3D", "[", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"jack", "[", 
             RowBox[{".25", ",", "0.0125"}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Opacity", "[", "0.1", "]"}], ",", 
            RowBox[{"Sphere", "[", "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Opacity", "[", "0.05", "]"}], ",", "\[IndentingNewLine]",
             "Blue", ",", 
            RowBox[{"Cylinder", "[", 
             RowBox[{"squish", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "e3"}], ",", "e3"}], "}"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "Red", ",", 
            RowBox[{"Cylinder", "[", 
             RowBox[{"squish", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "e1"}], ",", "e1"}], "}"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "Green", ",", 
            RowBox[{"Cylinder", "[", 
             RowBox[{"squish", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "e2"}], ",", "e2"}], "}"}]}], "]"}]}], "}"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"ParametricPlot3D", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"Sin", "[", 
                RowBox[{"\[Theta]", "[", "t", "]"}], "]"}], 
               RowBox[{"Cos", "[", 
                RowBox[{"\[Phi]", "[", "t", "]"}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Sin", "[", 
                RowBox[{"\[Theta]", "[", "t", "]"}], "]"}], 
               RowBox[{"Sin", "[", 
                RowBox[{"\[Phi]", "[", "t", "]"}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Cos", "[", 
               RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], "}"}], "/.", 
            "nsoln"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "0", ",", "tn"}], "}"}], ",", 
           RowBox[{"PlotRange", "->", "prl"}], ",", 
           RowBox[{"AspectRatio", "->", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1", ",", "1"}], "}"}]}]}], "]"}]}], "]"}]}], 
      "]"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.92512377217082*^9, 3.925123832723308*^9}, {
  3.925123878637959*^9, 3.9251238805029206`*^9}, {3.9251241941334057`*^9, 
