Cell[TextData[StyleBox["Lagrangian",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.924528847972241*^9, 
  3.924528850180431*^9}},ExpressionUUID->"184bf280-a5f9-4976-8b47-\
a5f2510e435e"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Generalized Coordinates and Velocities",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.925080830391897*^9, 
  3.9250808377531424`*^9}},ExpressionUUID->"f4563a12-a94b-4f71-8906-\
641fc5a4ac83"],

Cell[TextData[{
 "Choose generalized coordinates azimuth, ",
 Cell[BoxData[
  FormBox["\[Phi]", TraditionalForm]],ExpressionUUID->
  "24272296-6604-4da7-a293-997f50835d20"],
 ", co-elevation, \[Theta], and nodal angle about the spin axis, \[Psi], \
i.e., Euler angles in the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "b1906213-46c3-4fcd-9219-7e2b5f36b566"],
 "\[NoBreak]-\[NoBreak]convention \
(https://mathworld.wolfram.com/EulerAngles.html). "
}], "Text",
 CellChangeTimes->{{3.925041807586055*^9, 3.925042088928088*^9}, {
   3.925042170759093*^9, 3.925042253393009*^9}, {3.92504239090176*^9, 
   3.925042455538249*^9}, {3.9250484232417564`*^9, 3.925048509869336*^9}, {
   3.925053885645731*^9, 3.925054152836423*^9}, {3.9250541867797*^9, 
   3.925054200504951*^9}, {3.925056502296467*^9, 3.925056536890853*^9}, {
   3.925080849139813*^9, 3.9250808947203093`*^9}, {3.925080958878808*^9, 
   3.925080961351597*^9}, {3.92508109452715*^9, 3.925081247957396*^9}, {
   3.925081927580605*^9, 3.925081993170987*^9}, {3.92510952755987*^9, 
   3.925109530850526*^9}, {3.925109567599221*^9, 3.925109604349704*^9}, {
   3.925134071022488*^9, 3.925134093665495*^9}, {3.925147656402072*^9, 
   3.925147672877985*^9}, {3.925147805407559*^9, 3.92514780640958*^9}, 
