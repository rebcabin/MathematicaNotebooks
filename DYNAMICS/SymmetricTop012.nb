 CellLabel->"In[55]:=",ExpressionUUID->"31984d43-5d77-44b1-82d1-4f2620014589"],

Cell[TextData[{
 "Here is a playground with manipulable initial spin speed \[Psi]d, \
precession throw \[Phi]d, and dip angle ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b45f25e3-a735-4020-8929-94179040fb28"],
 ". See the obvious nutation and precession. "
}], "Text",
 CellChangeTimes->{{3.9251532460488243`*^9, 3.925153250096737*^9}, {
  3.944069001987331*^9, 3.9440690441835537`*^9}, {3.944403948643383*^9, 
  3.9444039634315577`*^9}, {3.944404036735361*^9, 3.944404057454603*^9}, {
  3.9444041709922028`*^9, 3.9444041771356564`*^9}, {3.944404235613126*^9, 
  3.944404274216304*^9}, {3.9444332046685123`*^9, 3.944433258825178*^9}, {
  3.94460261850056*^9, 3.944602666902178*^9}, {3.944646000121423*^9, 
  3.944646025073498*^9}, {3.944646080535623*^9, 
  3.944646126525016*^9}},ExpressionUUID->"6ae9c0b7-cfad-4b91-b085-\
e3bf978c8ea5"],

Cell[TextData[{
 "Amongst interesting exercises, check that, with no initial spin, the top \
just falls over, i.e., rotates around the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "d9cc8eb6-adf2-4d54-8766-652b953fbb95"],
 " axis because we don\[CloseCurlyQuote]t have a \[OpenCurlyDoubleQuote]hard \
floor\[CloseCurlyDoubleQuote]. This presages the inverted spherical pendulum, \
the next problem in this series of notebooks on discrete dynamics."
}], "Text",
 CellChangeTimes->{{3.9251532460488243`*^9, 3.925153250096737*^9}, {
  3.944069001987331*^9, 3.9440690441835537`*^9}, {3.944403948643383*^9, 
  3.9444039634315577`*^9}, {3.944404036735361*^9, 3.944404057454603*^9}, {
