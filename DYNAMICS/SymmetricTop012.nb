   3.925281982425309*^9}, {3.9258371535651093`*^9, 3.9258371590211887`*^9}, {
   3.925837195180385*^9, 3.925837226365538*^9}, {3.926155757906747*^9, 
   3.926155769752836*^9}, {3.926155851489935*^9, 3.92615591020817*^9}, {
   3.9261559952517223`*^9, 3.9261560300998497`*^9}, 3.9440645127078114`*^9, {
   3.944400177851136*^9, 3.944400192401248*^9}, {3.9446007003908253`*^9, 
   3.944600702408843*^9}, {3.945031854990859*^9, 
   3.945031936660946*^9}},ExpressionUUID->"33d14b86-0485-4144-bc71-\
3e67dc1c7838"],

Cell[TextData[{
 "The standard notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PartialD]", "L"}], "/", 
    RowBox[{"\[PartialD]", 
     OverscriptBox["\[Phi]", "\[Bullet]"]}]}], TraditionalForm]],
  ExpressionUUID->"da977d76-de99-4700-97ab-4ab40066014c"],
 " is a cruel pun. Consider the dedication of Reference 6, \
\[OpenCurlyDoubleQuote]",
 StyleBox["To all those who, like me, have wondered how in hell you can \
change ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   OverscriptBox["q", "\[Bullet]"], TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->
  "c353de6a-271e-4a6d-a3a4-55337922af7a"],
 StyleBox[" without changing ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox["q", TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->
  "81dd4c13-1df9-48ef-9964-aee5e2e05930"],
 ".\[CloseCurlyDoubleQuote] "
}], "Item",
 CellChangeTimes->{{3.925041807586055*^9, 3.925042088928088*^9}, {
   3.925042170759093*^9, 3.925042253393009*^9}, {3.92504239090176*^9, 
   3.925042455538249*^9}, {3.9250484232417564`*^9, 3.925048509869336*^9}, {
   3.925053885645731*^9, 3.925054152836423*^9}, {3.9250541867797*^9, 
   3.925054200504951*^9}, {3.925056502296467*^9, 3.925056536890853*^9}, {
   3.925080849139813*^9, 3.9250808947203093`*^9}, {3.925080958878808*^9, 
   3.925080961351597*^9}, {3.92508109452715*^9, 3.925081247957396*^9}, {
   3.925081927580605*^9, 3.925081993170987*^9}, {3.92510952755987*^9, 
   3.925109530850526*^9}, {3.925109567599221*^9, 3.925109604349704*^9}, {
   3.925134071022488*^9, 3.925134093665495*^9}, {3.925147656402072*^9, 
   3.925147672877985*^9}, {3.925147805407559*^9, 3.92514780640958*^9}, 
   3.925151666794215*^9, {3.925241801322153*^9, 3.925241901501216*^9}, {
   3.925243422179214*^9, 3.925243506053653*^9}, {3.925281981337427*^9, 
   3.925281982425309*^9}, {3.9258371535651093`*^9, 3.9258371590211887`*^9}, {
   3.925837195180385*^9, 3.925837226365538*^9}, {3.926155757906747*^9, 
   3.926155769752836*^9}, {3.926155851489935*^9, 3.92615591020817*^9}, {
   3.9261559952517223`*^9, 3.9261560300998497`*^9}, {3.944064519897159*^9, 
   3.944064568813966*^9}, {3.9440649626419907`*^9, 3.944064982288497*^9}, 
   3.944400212676302*^9, {3.944600723194213*^9, 3.944600750677718*^9}, {
   3.944605282973366*^9, 3.944605303071493*^9}, 3.944644325380052*^9, {
   3.9450319502119904`*^9, 
   3.9450319596799793`*^9}},ExpressionUUID->"2679c229-0e01-4bd3-89a0-\
148d6b829b7d"],

Cell[TextData[{
 "We can\[CloseCurlyQuote]t take the derivative of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "f7e2e2ee-c9c3-4ebd-88a9-8c5af109b4ae"],
 " with respect to the time derivative ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[Bullet]"], "=", 
    RowBox[{
     RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], TraditionalForm]],
  ExpressionUUID->"8362dc6a-ab35-4980-b68a-30772efc0018"],
 " of a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "[", "t", "]"}], TraditionalForm]],ExpressionUUID->
  "efcfacb3-99d2-4060-ad54-047467380601"],
 ". ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PartialD]", "L"}], "/", 
    RowBox[{"\[PartialD]", 
     OverscriptBox["\[Phi]", "\[Bullet]"]}]}], TraditionalForm]],
  ExpressionUUID->"106453f1-3323-437b-82d6-dcd1a7edbf6d"],
 " really means ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PartialD]", "L"}], "/", 
    RowBox[{"\[PartialD]", 
     RowBox[{"(", "\[Phi]d", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e8cbeab6-6b38-4501-9e8e-8f4e3d6aa467"],
 ", where ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     StyleBox["\[Phi]",
      FontSlant->"Plain"], 
     StyleBox["d",
      FontSlant->"Italic"]}]], TraditionalForm]],ExpressionUUID->
  "acc0f70d-c06a-417d-a456-1ddc23591bba"],
 " is an ordinary parameter variable of the arity\[NoBreak]-\[NoBreak]6 \
Lagrangian function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "[", 
    RowBox[{
    "\[Phi]", ",", "\[Theta]", ",", "\[Psi]", ",", "\[Phi]d", ",", 
     "\[Theta]d", ",", "\[Psi]d"}], "]"}], TraditionalForm]],ExpressionUUID->
  "9da801dd-c893-4c05-ab43-c0239120d633"],
 "."
}], "Item",
 CellChangeTimes->{{3.925041807586055*^9, 3.925042088928088*^9}, {
