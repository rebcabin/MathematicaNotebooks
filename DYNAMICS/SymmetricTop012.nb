360e30c21fb2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "L", ",", "F", ",", "V", ",", "T", ",", "q", ",", "\[Omega]", ",", 
    "\[Omega]2", ",", "\[Phi]", ",", "\[Theta]", ",", "\[Psi]", ",", 
    "\[Phi]d", ",", "\[Theta]d", ",", "\[Psi]d", ",", "I1", ",", "I3", ",", 
    " ", "l"}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.922450725517826*^9, 3.922450749500512*^9}, {
   3.922450785649948*^9, 3.922450796556322*^9}, {3.922452256079578*^9, 
