Cell[CellGroupData[{

Cell[TextData[StyleBox["Conjugate Momenta as Functions of State",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.9444019116588783`*^9, 
  3.944401922667379*^9}},ExpressionUUID->"75177917-056e-4537-8dcf-\
0d5678ffffaf"],

Cell[TextData[{
 "Define functions of the state ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "066b53a7-1e4d-44f3-adb7-74a95e55e18a"],
 " for the conjugate momenta. These will be valuable later for numerical \
comparisons."
}], "Text",
 CellChangeTimes->{{3.925061993465291*^9, 3.925062001143281*^9}, {
  3.925062918684534*^9, 3.925062920644117*^9}, {3.925894406736212*^9, 
  3.925894411034031*^9}, {3.9440654686131983`*^9, 3.944065486011599*^9}, {
  3.944601392038884*^9, 3.9446014277039137`*^9}, {3.944605786153887*^9, 
  3.944605788673979*^9}, {3.945032252965105*^9, 
  3.945032263572372*^9}},ExpressionUUID->"bdb4fa90-c0bb-4c72-9723-\
e7de5dc3bab5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"p\[Phi]", ",", "p\[Psi]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"p\[Phi]", "[", 
    RowBox[{"X", ":", 
     RowBox[{"{", 
      RowBox[{
      "\[Phi]_", ",", "\[Theta]_", ",", "\[Psi]_", ",", "\[Phi]d_", ",", 
       "\[Theta]d_", ",", "\[Psi]d_"}], "}"}]}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"I1", " ", 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "+", 
