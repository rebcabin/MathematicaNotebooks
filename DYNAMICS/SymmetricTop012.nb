   RowBox[{
    RowBox[{
     RowBox[{"f\[Theta]", "[", "u_", "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Theta]", "[", "t", "]"}], "/.", "nsoln"}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
