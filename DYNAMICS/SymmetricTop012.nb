Cell[CellGroupData[{

Cell[TextData[StyleBox["Outline",
 FontWeight->"Bold"]], "Section",
 CellChangeTimes->{{3.925028144181584*^9, 3.925028151114326*^9}, {
  3.9440619825810137`*^9, 3.944061985856249*^9}, {3.9440657384819403`*^9, 
  3.944065745954895*^9}, {3.9445651239005747`*^9, 
  3.944565143174752*^9}},ExpressionUUID->"d42f606d-4cc4-4863-a8da-\
bfb618cc7a18"],

Cell["Set up the problem.", "ItemNumbered",
 CellChangeTimes->{{3.924524236363361*^9, 3.924524280535631*^9}, {
  3.94456517324641*^9, 3.9445651812694407`*^9}, {3.9445652161536493`*^9, 
  3.944565240582827*^9}},ExpressionUUID->"d72b33d0-1700-4ce3-900e-\
efc4e501b204"],

Cell["\<\
Numerically solve the continuous Euler-Lagrange equations, vetting Reference \
4.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.924524236363361*^9, 3.924524280535631*^9}, {
  3.94456517324641*^9, 3.9445651812694407`*^9}, {3.944565217351487*^9, 
  3.9445652482791977`*^9}, {3.944565826335443*^9, 3.9445658766266527`*^9}, {
  3.944600404805726*^9, 3.9446004208153563`*^9}, {3.944605170974267*^9, 
  3.944605173896332*^9}},ExpressionUUID->"7d8b095e-7d4b-45d0-989a-\
c5d068b7b99b"],

Cell["\<\
Explore constants of the motion. Observe numerical drift in energy and \
momenta.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.924524236363361*^9, 3.924524280535631*^9}, {
  3.94456517324641*^9, 3.9445651812694407`*^9}, {3.944565217351487*^9, 
  3.944565294597269*^9}, {3.944565868470838*^9, 3.9445658722026787`*^9}, {
  3.944600430318849*^9, 3.944600437905931*^9}, {3.944605182207789*^9, 
  3.944605203639634*^9}, {3.944644163851864*^9, 
  3.944644164304388*^9}},ExpressionUUID->"a43ff1b0-aa65-4e18-bbdb-\
1521436118eb"],

Cell["\<\
Formulate and solve the discrete Lagrangian. Compare results with the \
continuous solution. Observe only stable oscillatory noise.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.924524236363361*^9, 3.924524280535631*^9}, {
   3.94456517324641*^9, 3.9445651812694407`*^9}, {3.944565217351487*^9, 
   3.944565344226231*^9}, {3.9446052120398607`*^9, 3.9446052285885572`*^9}, {
   3.9446441728750257`*^9, 3.944644190852522*^9}, 
   3.944668196339851*^9},ExpressionUUID->"4d37c4da-93df-418e-94ec-\
87e120b5e978"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Problem Set-Up",
 FontWeight->"Bold"]], "Section",
 CellChangeTimes->{{3.944565131142337*^9, 3.944565136122518*^9}, {
  3.944565207776066*^9, 
  3.944565210566659*^9}},ExpressionUUID->"3bf7cee7-b951-408c-a9a5-\
51568c2f7f28"],

Cell[TextData[{
 "There are four parameters or ",
 StyleBox["free variables",
  FontSlant->"Italic"],
 " for the problem. Because the top is symmetrical about its spinning axis, \
its moment-of-inertia tensor has only two independent components, free \
variables ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "1"], TraditionalForm]],ExpressionUUID->
  "cb290ed8-cc0b-4a6e-bd97-dd649c84ebda"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "3"], TraditionalForm]],ExpressionUUID->
  "d3458533-283d-46bf-81c4-839744d26988"],
 ". Alternatively, we can model the top as an oblate spheroid with semi-major \
axis ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8088de18-c391-49e7-9d4d-cb74147f0c0b"],
 " and equatorial radius ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9563ae4a-ed0d-4bb5-bc80-98ee651a5b68"],
 " as free variables."
}], "Text",
 CellChangeTimes->{{3.925974521408366*^9, 3.925974586684314*^9}, {
   3.925974652187598*^9, 3.925974741688865*^9}, {3.944061926769589*^9, 
   3.94406199415814*^9}, {3.944062168521893*^9, 3.944062256450008*^9}, {
   3.94406243261351*^9, 3.9440624662653093`*^9}, {3.944062567786243*^9, 
   3.944062580610981*^9}, {3.944064631265779*^9, 3.944064675604644*^9}, {
   3.944064728531334*^9, 3.944064731635543*^9}, {3.9440657499069033`*^9, 
   3.94406576611696*^9}, {3.944399803372189*^9, 3.944399843437772*^9}, {
   3.94456672260032*^9, 3.944566788747054*^9}, {3.9445671455477047`*^9, 
   3.944567230819333*^9}, {3.944567316785199*^9, 3.944567318568671*^9}, {
   3.9445673527382717`*^9, 3.9445673536528397`*^9}, {3.944600463579362*^9, 
   3.944600661883152*^9}, 3.9446052464437313`*^9, {3.944644202891746*^9, 
   3.9446442823701773`*^9}, {3.944668210478623*^9, 
   3.944668227590973*^9}},ExpressionUUID->"05c03b50-3fd3-402e-a9ff-\
0d23266781b4"],

Cell[TextData[{
 "The acceleration of gravity ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "2c738593-dda8-4426-b850-137746b062f8"],
 " and the mass ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "3c6fd478-8866-4a24-886c-5aae06f89b98"],
 " of the top are the other two free variables."
}], "Text",
 CellChangeTimes->{{3.925974521408366*^9, 3.925974586684314*^9}, {
  3.925974652187598*^9, 3.925974741688865*^9}, {3.944061926769589*^9, 
  3.94406199415814*^9}, {3.944062168521893*^9, 3.944062256450008*^9}, {
  3.94406243261351*^9, 3.9440624662653093`*^9}, {3.944062567786243*^9, 
  3.944062580610981*^9}, {3.944064631265779*^9, 3.944064675604644*^9}, {
  3.944064728531334*^9, 3.944064731635543*^9}, {3.9440657499069033`*^9, 
  3.94406576611696*^9}, {3.944399803372189*^9, 3.944399815439793*^9}, {
  3.9443998656910152`*^9, 
  3.944399868629012*^9}},ExpressionUUID->"98f3dc94-860a-4105-8817-\
4d5033966c91"]
}, Open  ]],

