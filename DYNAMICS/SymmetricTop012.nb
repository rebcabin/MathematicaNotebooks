Cell[CellGroupData[{

Cell[TextData[StyleBox["Checked",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.925248092538253*^9, 3.925248096739768*^9}, {
  3.92524877872988*^9, 3.9252487808134317`*^9}, {3.925280942628667*^9, 
  3.925280949735695*^9}},ExpressionUUID->"05214b4c-aac6-4ffa-a96f-\
09416378581c"],

Cell["\<\
Energy, about 14 Joule, is conserved to five figures. It is, however, \
trending upwards due to numerical effects, which we will not see in the \
discrete solution. \
\>", "Text",
 CellChangeTimes->{{3.925246118145756*^9, 3.925246202551597*^9}, {
  3.925281648901782*^9, 3.925281659378683*^9}, {3.9258389659646177`*^9, 
  3.925838972152333*^9}, {3.925839202838566*^9, 3.925839205271896*^9}, {
  3.925888499418048*^9, 3.9258885215911627`*^9}, {3.944066082720701*^9, 
  3.9440660831971073`*^9}, {3.944066294746374*^9, 3.944066333211842*^9}, {
  3.944401669765563*^9, 3.944401673076539*^9}, {3.944568055568939*^9, 
  3.9445680923546753`*^9}, {3.94460228414781*^9, 3.94460231285802*^9}, {
  3.94464560287805*^9, 3.944645617174148*^9}, {3.944645662606188*^9, 
  3.944645682506257*^9}, {3.944645864460701*^9, 
  3.944645876465741*^9}},ExpressionUUID->"c4328105-f8e6-419f-9133-\
c935ad5e6198"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "displayResidualEnergy", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"displayResidualEnergy", "[", 
    RowBox[{"Efunction_", ",", "label_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "f\[Phi]", ",", "f\[Theta]", ",", "f\[Psi]", ",", "X", ",", "meanEf"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"f\[Phi]", "[", "u_", "]"}], ":=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Phi]", "[", "t", "]"}], "/.", 
            RowBox[{"nsoln", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"f\[Theta]", "[", "u_", "]"}], ":=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Theta]", "[", "t", "]"}], "/.", 
            RowBox[{"nsoln", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"f\[Psi]", "[", "u_", "]"}], ":=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Psi]", "[", "t", "]"}], "/.", 
            RowBox[{"nsoln", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"X", "[", "u_", "]"}], ":=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"f\[Phi]", "[", "u", "]"}], ",", 
          RowBox[{"f\[Theta]", "[", "u", "]"}], ",", 
          RowBox[{"f\[Psi]", "[", "u", "]"}], ",", 
          RowBox[{
           RowBox[{"f\[Phi]", "'"}], "[", "u", "]"}], ",", 
          RowBox[{
           RowBox[{"f\[Theta]", "'"}], "[", "u", "]"}], ",", 
          RowBox[{
           RowBox[{"f\[Psi]", "'"}], "[", "u", "]"}]}], "}"}]}], ";"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "mean", " ", "Energy", " ", "of", " ", "the", " ", "entire", " ", 
        "run"}], " ", "*)"}], ";", "\[IndentingNewLine]", 
      RowBox[{"meanEf", "=", 
       RowBox[{"Echo", "@", 
        RowBox[{"Mean", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Efunction", "[", 
              RowBox[{"X", "[", "u", "]"}], "]"}], "/.", "numRules4"}], ")"}],
            ",", 
           RowBox[{"{", 
            RowBox[{"u", ",", "0", ",", "tN", ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"tN", "-", "0"}], ")"}], "/", "100"}]}], "}"}]}], 
          "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Efunction", "[", 
            RowBox[{"X", "[", "u", "]"}], "]"}], "/.", "numRules4"}], ")"}], "-",
          "meanEf"}], ",", 
        RowBox[{"{", 
         RowBox[{"u", ",", "0", ",", "tN"}], "}"}], ",", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Energy [Joule]\>\"", ",", "\"\<\>\""}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\"\<Time [sec]\>\"", ",", "\"\<\>\""}], "}"}]}], "}"}]}],
         ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "->", "label"}], ",", 
        RowBox[{"Frame", "->", "Automatic"}], ",", 
        RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
