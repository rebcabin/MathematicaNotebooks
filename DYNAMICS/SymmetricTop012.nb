   3.945031790941408*^9, 
   3.9450318047263927`*^9}},ExpressionUUID->"a7bc1a1e-6f80-49b6-b2b8-\
853a87a37206"],

Cell[TextData[{
 "The corresponding generalized velocities are ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Phi]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "2fa08f4d-584f-4b9c-aeed-d13bed6a7a69"],
 ", ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Theta]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "3fe94643-d06e-47e6-8ba9-26f7bda37294"],
 ", and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Psi]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "2c31b0a8-b54b-482c-b2d1-a75938a8db5b"],
 ", written as \[Phi]d, \[Theta]d, \[Psi]d because ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Phi]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "e6bf960e-d034-4de2-a4e3-ed27482995b6"],
 ", ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Theta]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "6025ea5e-1738-4834-a954-b2e344b972f3"],
 ", and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Psi]", "\[Bullet]"], TraditionalForm]],ExpressionUUID->
  "45e15cc5-80b7-4445-a6bb-785c08fff986"],
 " are not valid Mathematica syntax for variables. "
}], "Text",
 CellChangeTimes->{{3.925041807586055*^9, 3.925042088928088*^9}, {
   3.925042170759093*^9, 3.925042253393009*^9}, {3.92504239090176*^9, 
