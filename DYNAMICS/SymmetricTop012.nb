Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"jack", ",", "eulerRotate"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"o", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"e1", "=", 
      RowBox[{"{", 
       RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"e2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], ",", 
     RowBox[{"e3", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"tip", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", 
     RowBox[{"pr", "=", "1.25"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"eulerRotate", "[", 
      RowBox[{"obj_", ",", "\[Phi]_", ",", "\[Theta]_", ",", "\[Psi]_"}], 
      "]"}], ":=", "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r3", "=", 
         RowBox[{"RotationMatrix", "[", 
          RowBox[{"\[Phi]", ",", "e3"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"e1Prime", "=", 
           RowBox[{"r3", ".", "e1"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"e3DoublePrime", "=", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"RotationMatrix", "[", 
               RowBox[{"\[Theta]", ",", "e1Prime"}], "]"}], ".", "r3", ".", 
              "e3"}]}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Rotate", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Rotate", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Rotate", "[", "\[IndentingNewLine]", 
                RowBox[{
                "obj", ",", "\[IndentingNewLine]", "\[Phi]", ",", "e3"}], 
                "]"}], ",", "\[IndentingNewLine]", "\[Theta]", ",", 
               "e1Prime"}], "]"}], ",", "\[IndentingNewLine]", "\[Psi]", ",", 
             "e3DoublePrime"}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"jack", "[", 
      RowBox[{
       RowBox[{"opacity_", ":", "0.1"}], ",", 
       RowBox[{"diameter_", ":", "0.01"}]}], "]"}], ":=", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Opacity", "[", "opacity", "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", "e1"}], "}"}], ",", "diameter"}], "]"}], 
          "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Darker", "[", "Green", "]"}], ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", "e2"}], "}"}], ",", "diameter"}], "]"}], 
          "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", "e3"}], "}"}], ",", "diameter"}], "]"}], 
          "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Lighter", "[", "Cyan", "]"}], ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", 
              RowBox[{"-", "e1"}]}], "}"}], ",", "diameter"}], "]"}], "]"}]}],
         "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Magenta", ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", 
              RowBox[{"-", "e2"}]}], "}"}], ",", "diameter"}], "]"}], "]"}]}],
         "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Yellow", ",", 
         RowBox[{"Arrow", "[", 
          RowBox[{"Tube", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", 
              RowBox[{"-", "e3"}]}], "}"}], ",", "diameter"}], "]"}], "]"}]}],
         "}"}]}], "}"}]}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.92511025985674*^9, 3.925110393908043*^9}, {
   3.925110437260689*^9, 3.925110460698225*^9}, {3.925110501962219*^9, 
