Cell[CellGroupData[{

Cell[TextData[StyleBox["Funny Plotting Business",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.925246482584777*^9, 3.925246487800906*^9}, {
  3.92597392251653*^9, 3.925973924666394*^9}, {3.926153583133511*^9, 
  3.926153584870262*^9}, {3.944066030508711*^9, 
  3.944066031278111*^9}},ExpressionUUID->"740398b3-1688-48ab-ac58-\
254dea7d5432"],

Cell[TextData[{
 "We need time derivatives of the angles to plot energy and momentum. It\
\[CloseCurlyQuote]s not immediately straightforward to compute derivatives of \
 ",
 StyleBox["NDsolve", "Input"],
 "\[CloseCurlyQuote]s results, which are not functions, rather expressions \
depending on the hard-coded parameter ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "fbc4f56e-60d2-486b-8f42-202b9305a13a"],
 ". Mathematica\[CloseCurlyQuote]s ",
 StyleBox["Derivative", "Input"],
 " function requires functions, not expressions. "
}], "Text",
 CellChangeTimes->{{3.925243843733622*^9, 3.925243929174502*^9}, {
  3.925243961308188*^9, 3.925244099219236*^9}, {3.925244416087654*^9, 
  3.925244476966249*^9}, {3.9252465171531763`*^9, 3.9252465310839863`*^9}, {
  3.925247985226598*^9, 3.925248070344753*^9}, {3.9440658813879766`*^9, 
  3.944065915023497*^9}, {3.9440660475939417`*^9, 3.944066048175989*^9}, {
  3.944401569044776*^9, 3.9444015715848207`*^9}, {3.944510584110304*^9, 
  3.94451062082607*^9}, {3.9445109184383717`*^9, 3.944510937396847*^9}, {
  3.94456791872055*^9, 3.9445680100239677`*^9}, {3.944602032909384*^9, 
  3.944602071359222*^9}, {3.944645507056477*^9, 3.9446455674367933`*^9}, {
  3.945032479250635*^9, 3.945032492026328*^9}, {3.945032554836652*^9, 
  3.945032555604792*^9}},ExpressionUUID->"19cb52e6-0005-49ca-a003-\
44cc9183332f"],

Cell[TextData[{
 "Convert the expressions to functions. Also, avoid the ",
 StyleBox["Symbol", "Input"],
 " ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "adbc4252-5b75-41da-ab7b-77deb876e29a"],
 ", even if encapsulated in ",
 StyleBox["Modules", "Input"],
 " or as dummy variables in ",
 StyleBox["Plot", "Input"],
 ". To wit, the following silently failed:"
}], "Text",
 CellChangeTimes->{{3.925243843733622*^9, 3.925243929174502*^9}, {
  3.925243961308188*^9, 3.925244099219236*^9}, {3.925244416087654*^9, 
  3.925244476966249*^9}, {3.9252465171531763`*^9, 3.9252465310839863`*^9}, {
  3.925247985226598*^9, 3.925248070344753*^9}, {3.9440658813879766`*^9, 
  3.944065915023497*^9}, {3.9440660475939417`*^9, 3.944066048175989*^9}, {
  3.944401569044776*^9, 3.9444015715848207`*^9}, {3.944510584110304*^9, 
  3.94451062082607*^9}, {3.9445109184383717`*^9, 3.944510937396847*^9}, {
  3.94456791872055*^9, 3.9445679883496017`*^9}, {3.945032601567019*^9, 
  3.945032605419361*^9}},ExpressionUUID->"186d222e-2ce4-4bba-942a-\
35e88f89e945"],

