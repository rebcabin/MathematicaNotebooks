Cell[TextData[{
 "The second and larger conserved energy, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "2"], TraditionalForm]],ExpressionUUID->
  "36b8af54-8fd4-4e9d-8c60-5accdc3c3cf9"],
 ", is the kinetic energy of spin plus the kinetic energy due to the (larger) \
precession component, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]d", " ", "cos", " ", "\[Theta]"}], TraditionalForm]],
  ExpressionUUID->"d68ce5bb-a3a3-4b0b-ab2c-10f56d114d09"],
 ", parallel to the instantaneous axis of rotation:"
}], "Text",
