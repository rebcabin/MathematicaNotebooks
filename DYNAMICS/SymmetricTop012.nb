Cell[TextData[{
 "It turns out that two addends of energy are separately conserved, again \
with small, pesky drifts. The first and smaller, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "1"], TraditionalForm]],ExpressionUUID->
  "25e9cc6b-4829-43e7-bcd9-9496ebd3d451"],
 ", is the potential energy plus the kinetic energy of nutation angle \
\[Theta] plus the kinetic energy due to the (smaller) precession component, \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]d", " ", "sin", " ", "\[Theta]"}], TraditionalForm]],
  ExpressionUUID->"93de4b2a-cd28-4aef-b9e3-e3c75de92ce1"],
 ", perpendicular to the instantaneous axis of rotation:"
}], "Text",
 CellChangeTimes->{{3.925940153425468*^9, 3.9259402028797417`*^9}, {
  3.925940244682678*^9, 3.925940305943937*^9}, {3.926157664072043*^9, 
  3.926157713223728*^9}, {3.9440664049031363`*^9, 3.9440665083102713`*^9}, {
