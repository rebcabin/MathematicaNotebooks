Cell[TextData[{
 "The following DOES work, so long as the dummy variable in ",
 StyleBox["Plot", "Input"],
 " is anything ",
 StyleBox["except",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   StyleBox["t", "Input",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "56871b8c-fded-41e0-95a5-b910330efbe8"],
 ":"
}], "Text",
 CellChangeTimes->{{3.925244505975111*^9, 3.925244520598196*^9}, {
