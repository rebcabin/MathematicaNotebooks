Cell[TextData[{
 "Now see dimensions of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"mass", " ", "*", " ", 
    RowBox[{
     SuperscriptBox["length", "2"], "/", "time"}]}], TraditionalForm]],
  ExpressionUUID->"c5231df7-8dc5-4de8-bb60-6f3e954cc6b6"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"mass", " ", "*", " ", 
    RowBox[{
     SuperscriptBox["length", "2"], "/", 
     SuperscriptBox["time", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "8329da5f-3f4b-49c6-85c4-b449813a9b75"],
 ". The second factor of time in the denominator returns via ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DifferentialD]", 
    RowBox[{"/", 
     RowBox[{"\[DifferentialD]", "t"}]}]}], TraditionalForm]],ExpressionUUID->
  "e3b3e30c-fb8f-4323-8332-06d0bc3f048e"],
 "."
}], "Text",
 CellChangeTimes->{{3.925058982755242*^9, 3.925059084268985*^9}, {
  3.925062108548184*^9, 3.925062117035249*^9}, {3.925084123117494*^9, 
  3.925084125974146*^9}, {3.944400750218066*^9, 3.94440079100765*^9}, {
  3.9444811862749577`*^9, 3.944481192891184*^9}, {3.9445676045046673`*^9, 
  3.944567608585966*^9}},ExpressionUUID->"bb626333-507c-43d3-9ac2-\
40adca8f3990"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Conjugate Momenta",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.925062074664067*^9, 3.925062085302558*^9}, 
   3.925283939949391*^9},ExpressionUUID->"f56f0a35-7324-4cbf-94c7-\
04f83dcc4671"],

Cell[TextData[{
 "For any Lagrangian, ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", "L"}], 
    RowBox[{"\[PartialD]", 
     OverscriptBox["q", "\[Bullet]"]}]], TraditionalForm]],
  CellChangeTimes->{{3.924524848285441*^9, 3.924524934048407*^9}, {
   3.924524986409487*^9, 3.924525012966354*^9}, {3.925055090022418*^9, 
   3.925055092374092*^9}},ExpressionUUID->
  "6a39aa7a-8893-498e-aa08-538e2773bfa1"],
 " (pun intended) are the ",
 StyleBox["conjugate momenta",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "q"], TraditionalForm]],ExpressionUUID->
  "fb70f671-7f85-4751-a32a-75fe68e5a8f2"],
 ". In our case, the first, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "\[Phi]"], "=", 
    FractionBox[
     RowBox[{"\[PartialD]", "L"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Phi]", "\[Bullet]"]}]]}], TraditionalForm]],
  ExpressionUUID->"9df299a1-296f-4268-b51c-1e7da13deed2"],
 ", and the third, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "\[Psi]"], "=", 
    FractionBox[
     RowBox[{"\[PartialD]", "L"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Psi]", "\[Bullet]"]}]]}], TraditionalForm]],
  ExpressionUUID->"da55a6fe-084a-4fdd-a9c3-8da4823d4ee8"],
 ", are ",
 StyleBox["conserved momenta",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", or ",
 StyleBox["constants of the motion",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ".",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", "L"}], 
    RowBox[{"\[PartialD]", "\[Phi]"}]], TraditionalForm]],ExpressionUUID->
  "9862aac3-a427-45a6-85cc-874fda9f2875"],
 " and ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", "L"}], 
    RowBox[{"\[PartialD]", "\[Psi]"}]], TraditionalForm]],ExpressionUUID->
  "cbd6b53e-ee43-4326-be37-e447ce036342"],
 " are zero, thus so are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[DifferentialD]", 
      RowBox[{"\[DifferentialD]", "t"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"\[PartialD]", "L"}], 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Phi]", "\[Bullet]"]}]], ")"}]}], "=", 
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["p", "\[Phi]"]}], 
     RowBox[{"\[DifferentialD]", "t"}]]}], TraditionalForm]],ExpressionUUID->
  "79f26020-3954-4962-b073-ef9d3a6a6fe4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[DifferentialD]", 
      RowBox[{"\[DifferentialD]", "t"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"\[PartialD]", "L"}], 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Psi]", "\[Bullet]"]}]], ")"}]}], "=", 
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["p", "\[Psi]"]}], 
     RowBox[{"\[DifferentialD]", "t"}]]}], TraditionalForm]],ExpressionUUID->
  "fd475ed3-c41e-41c7-91c6-fb9f3a9ed7a6"],
 " by the Euler-Lagrange equations; ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "\[Phi]"], TraditionalForm]],ExpressionUUID->
  "d5f81146-9ca4-4190-b952-c27db032f1f2"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "\[Psi]"], TraditionalForm]],ExpressionUUID->
  "53073a76-6c51-4cd0-9f73-6354ac4e63cf"],
 " must be constant because their time derivatives vanish. This is an \
application of Noether\[CloseCurlyQuote]s Theorem. "
}], "Text",
 CellChangeTimes->{{3.9250597304859667`*^9, 3.925059809158147*^9}, {
  3.9250598537036667`*^9, 3.925059874740175*^9}, {3.925059908643495*^9, 
  3.925060238022501*^9}, {3.925062516021759*^9, 3.92506252583656*^9}, {
  3.925084161303831*^9, 3.925084272139385*^9}, {3.9250843516887302`*^9, 
  3.925084400868129*^9}, {3.92510986873781*^9, 3.925109909822542*^9}, {
  3.925152462942564*^9, 3.9251524911529903`*^9}, {3.944065370429242*^9, 
  3.944065409656404*^9}, {3.944400819587696*^9, 3.944401005238449*^9}, {
  3.944567628149722*^9, 3.9445676334508343`*^9}, {3.94456767099888*^9, 
  3.9445676842923*^9}, {3.944601361534786*^9, 3.944601369281534*^9}, {
  3.944605670743568*^9, 3.944605769838318*^9}, {3.944605886190896*^9, 
  3.944605891352125*^9}, {3.944644757530672*^9, 3.944644786630001*^9}, {
  3.9450321363754063`*^9, 
  3.945032187009794*^9}},ExpressionUUID->"3cc08372-c70e-49ec-8df9-\
a3bba771f037"],

Cell["\<\
Reference 5 exhibits alternative, first-order equations of motion via these \
constants. We have, in a separate notebook, shown that References 4 and 5 are \
mutually consistent.\
\>", "Text",
 CellChangeTimes->{{3.9250597304859667`*^9, 3.925059809158147*^9}, {
  3.9250598537036667`*^9, 3.925059874740175*^9}, {3.925059908643495*^9, 
