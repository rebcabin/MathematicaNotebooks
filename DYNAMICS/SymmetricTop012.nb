Cell[CellGroupData[{

Cell[TextData[StyleBox["Conservation of Momenta",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.925246598521098*^9, 
  3.925246607057538*^9}},ExpressionUUID->"4032d98f-c80d-40eb-a5ef-\
5ed4eac8c5a7"],

Cell[TextData[{
 "Check conservation of azimuthal ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "\[Phi]"], TraditionalForm]],ExpressionUUID->
  "2c65c359-1de8-4fb4-ab06-9ae9971bf9b0"],
 " and nodal ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "\[Psi]"], TraditionalForm]],ExpressionUUID->
  "c196dd3b-947d-41c9-8f65-ce02f3126336"],
 " momenta via the functional forms defined above. See conservation within \
six figures with opposite drifts."
}], "Text",
 CellChangeTimes->{{3.92524674406345*^9, 3.92524678321237*^9}, {
  3.925248111025655*^9, 3.925248118030115*^9}, {3.925898018567039*^9, 
  3.925898046688035*^9}, {3.925898469579012*^9, 3.925898473593178*^9}, {
  3.9440676370596657`*^9, 3.944067667031115*^9}, {3.944401861672628*^9, 
  3.944401875434654*^9}, {3.9446025325735064`*^9, 
  3.944602559999734*^9}},ExpressionUUID->"418687c7-63a2-46c1-b287-\
2161f9c68a59"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "f\[Phi]", ",", "f\[Theta]", ",", "f\[Psi]", ",", "X", ",", "meanP\[Phi]",
      ",", "meanP\[Psi]"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"f\[Phi]", "[", "u_", "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Phi]", "[", "t", "]"}], "/.", 
         RowBox[{"nsoln", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"f\[Theta]", "[", "u_", "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Theta]", "[", "t", "]"}], "/.", 
         RowBox[{"nsoln", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"f\[Psi]", "[", "u_", "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Psi]", "[", "t", "]"}], "/.", 
         RowBox[{"nsoln", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"X", "[", "u_", "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"f\[Phi]", "[", "u", "]"}], ",", 
       RowBox[{"f\[Theta]", "[", "u", "]"}], ",", 
       RowBox[{"f\[Psi]", "[", "u", "]"}], ",", 
       RowBox[{
        RowBox[{"f\[Phi]", "'"}], "[", "u", "]"}], ",", 
       RowBox[{
        RowBox[{"f\[Theta]", "'"}], "[", "u", "]"}], ",", 
       RowBox[{
        RowBox[{"f\[Psi]", "'"}], "[", "u", "]"}]}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"meanP\[Phi]", "=", 
     RowBox[{"Echo", "@", 
      RowBox[{"Mean", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"p\[Phi]", "[", 
           RowBox[{"X", "[", "u", "]"}], "]"}], "/.", "numRules4"}], ",", 
         RowBox[{"{", 
