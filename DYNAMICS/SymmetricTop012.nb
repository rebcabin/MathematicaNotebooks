Cell[CellGroupData[{

Cell[TextData[StyleBox["Kinetic Energy",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.925054902625161*^9, 
  3.925054905407262*^9}},ExpressionUUID->"9ef1a9e1-c78c-4200-aa20-\
8c8f39097e87"],

Cell[TextData[{
 "Consider an inertial reference frame instantaneously oriented with the \
current Euler angles of the top, but not rotating with the top. Measure the \
overall angular-velocity vector of the top in this frame in terms of the time \
derivatives of the angles. Write kinetic energy in terms of that \
angular-velocity vector in that frame. Denote the 6\[NoBreak]-\[NoBreak]tuple \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
    "\[Phi]", ",", "\[Theta]", ",", "\[Psi]", ",", "\[Phi]d", ",", 
     "\[Theta]d", ",", "\[Psi]d"}], "}"}], TraditionalForm]],ExpressionUUID->
  "9e3f6721-247c-4b45-8ab1-c7ae437ce64d"],
 " as the ",
 StyleBox["state vector",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "c711c0be-40ff-47ae-85cc-0bd3e6fa750b"],
 ". The ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}], TraditionalForm]],ExpressionUUID->
  "d8f26441-dfab-4c00-a073-4ef799864b09"],
 " notation in the kinetic-energy formula merely fetches the scalar value \
from the one-and-only slot in the matrix formula."
}], "Text",
 CellChangeTimes->{{3.925052529818605*^9, 3.9250525489608088`*^9}, {
  3.925081337685686*^9, 3.925081339850525*^9}, {3.926059785881078*^9, 
  3.926059802489365*^9}, {3.926060368231765*^9, 3.9260604409946547`*^9}, {
  3.926071341851173*^9, 3.926071501238324*^9}, {3.926152340322578*^9, 
  3.9261525255750933`*^9}, {3.9261559598848886`*^9, 3.926155987195224*^9}, {
  3.926156592097124*^9, 3.926156614527431*^9}, {3.944065052556408*^9, 
  3.9440650556244926`*^9}, {3.944400327150865*^9, 3.9444005032488947`*^9}, {
  3.944481047823683*^9, 3.944481052249091*^9}, {3.94448109871139*^9, 
  3.9444811030062523`*^9}, {3.944568509194051*^9, 3.9445685740876207`*^9}, {
  3.944600952641512*^9, 3.944600953257106*^9}, {3.944644431227296*^9, 
  3.944644536896699*^9}},ExpressionUUID->"ee5f704a-a10d-4489-a7b1-\
a00ba918f8a5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"M", ",", "L", ",", "T"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{"(", GridBox[{
      {"I1", "0", "0"},
      {"0", "I1", "0"},
      {"0", "0", "I3"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]", "[", 
    RowBox[{"{", 
     RowBox[{
     "\[Phi]_", ",", "\[Theta]_", ",", "\[Psi]_", ",", "\[Phi]d_", ",", 
      "\[Theta]d_", ",", "\[Psi]d_"}], "}"}], "]"}], ":=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Phi]d", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Sin", "[", "\[Psi]", "]"}]}], "+", 
       RowBox[{"\[Theta]d", " ", 
        RowBox[{"Cos", "[", "\[Psi]", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Phi]d", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Psi]", "]"}]}], "-", 
       RowBox[{"\[Theta]d", " ", 
        RowBox[{"Sin", "[", "\[Psi]", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Phi]d", " ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "+", "\[Psi]d"}], "}"}]}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"T", "[", 
    RowBox[{"X", ":", 
     RowBox[{"{", 
      RowBox[{
      "\[Phi]_", ",", "\[Theta]_", ",", "\[Psi]_", ",", "\[Phi]d_", ",", 
       "\[Theta]d_", ",", "\[Psi]d_"}], "}"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       RowBox[{
        RowBox[{"\[Omega]", "[", "X", "]"}], "\[Transpose]"}], ".", "M", ".", 
       
       RowBox[{"\[Omega]", "[", "X", "]"}]}]}], ")"}], "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"L", "[", 
    RowBox[{"X", ":", 
     RowBox[{"{", 
      RowBox[{
      "\[Phi]_", ",", "\[Theta]_", ",", "\[Psi]_", ",", "\[Phi]d_", ",", 
       "\[Theta]d_", ",", "\[Psi]d_"}], "}"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"T", "[", "X", "]"}], "-", 
    RowBox[{"V", "[", "X", "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.925051522431599*^9, 3.925051585343746*^9}, {
   3.925052931347868*^9, 3.925052956891537*^9}, {3.925052987511159*^9, 
