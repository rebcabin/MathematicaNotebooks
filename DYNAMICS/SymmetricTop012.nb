0d63ea52ed41"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "f\[Theta]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"f\[Theta]", "[", "u_", "]"}], ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Theta]", "[", "t", "]"}], "/.", 
         RowBox[{"nsoln", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", "u"}], "}"}]}], ")"}]}], ";", 
    "\[IndentingNewLine]", 
    StyleBox[
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"f\[Theta]", "[", "u", "]"}], ",", 
         RowBox[{
          RowBox[{"f\[Theta]", "'"}], "[", "u", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"u", ",", "0", ",", "tN"}], "}"}]}], "]"}],
     Background->RGBColor[1, 1, 0]]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.925244107944881*^9, 3.925244399577061*^9}, {
  3.925246233015823*^9, 3.925246233641075*^9}, {3.925246720875188*^9, 
  3.925246721861917*^9}},
