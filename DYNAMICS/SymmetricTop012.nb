   3.925042622165553*^9}, {3.925048375271607*^9, 3.92504838397544*^9}, {
   3.925050281290983*^9, 3.925050292506715*^9}, {3.925050348665641*^9, 
   3.925050351210915*^9}, {3.926059696165518*^9, 3.9260597007490597`*^9}, {
   3.944600774073382*^9, 3.944600774379301*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"7e984e96-8dcb-4e87-9dae-1186d2886d3f"],

