  3.9446461152936497`*^9}},ExpressionUUID->"bb3a3817-a33d-4a77-8a4e-\
66bbc1369697"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"initials", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Phi]", "[", "0", "]"}], "==", 
         RowBox[{"0", "\[Degree]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Theta]", "'"}], "[", "0", "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"\[Psi]", "[", "0", "]"}], "==", 
         RowBox[{"0", "\[Degree]"}]}]}], "}"}]}], ",", "\[IndentingNewLine]", 
     
     RowBox[{"eqns", "=", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"hardEqns", "/.", "fTimeRules"}], "/.", "numRules4"}], 
       ")"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nsoln", "=", 
         RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"eqns", "~", "Join", "~", "initials", "~", "Join", "~", 
            RowBox[{"{", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"\[Psi]", "'"}], "[", "0", "]"}], "==", "\[Psi]d0"}], 
              ",", 
              RowBox[{
               RowBox[{"\[Theta]", "[", "0", "]"}], "==", 
               RowBox[{"\[Theta]0", " ", "\[Degree]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"\[Phi]", "'"}], "[", "0", "]"}], "==", 
               "\[Phi]d0"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
             RowBox[{"\[Theta]", "[", "t", "]"}], ",", 
             RowBox[{"\[Psi]", "[", "t", "]"}]}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"t", ",", "0", ",", "tn"}], "}"}]}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"renderSoln", "[", 
        RowBox[{"nsoln", ",", "tn"}], "]"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "tn", ",", "70", 
         ",", "\"\<\!\(\*SubscriptBox[\(t\), \(N\)]\)[sec]\>\""}], "}"}], ",",
        "0", ",", "140", ",", 
       RowBox[{"Appearance", "->", "\"\<Open\>\""}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\[Phi]d0", ",", "0", 
         ",", "\"\<\!\(\*OverscriptBox[\(\[Phi]\), \(.\)]\)[rad/s]\>\""}], 
        "}"}], ",", "0", ",", "3", ",", 
       RowBox[{"Appearance", "->", "\"\<Open\>\""}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Psi]d0", ",", "5", ",", "\"\<spin[rad/s]\>\""}], "}"}], ",",
        "0", ",", "30", ",", 
       RowBox[{"Appearance", "->", "\"\<Open\>\""}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]0", ",", "42", ",", "\"\<dip[deg]\>\""}], "}"}], ",",
        "0", ",", "90", ",", 
       RowBox[{"Appearance", "->", "\"\<Open\>\""}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.944402854890349*^9, 3.9444028709605713`*^9}, {
