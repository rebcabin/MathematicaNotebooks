             RowBox[{"0.5", ",", 
              RowBox[{"{", 
               RowBox[{"0.5", ",", "0.5"}], "}"}]}], "}"}]}], "]"}]}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0.75", ",", 
              RowBox[{"{", 
               RowBox[{"0.5", ",", "0.5"}], "}"}]}], "}"}], " ", "slides", " ",
             "it", " ", "down", " ", "the", " ", "curve"}], ",", 
           RowBox[{
            RowBox[{"keeping", " ", "the", " ", "text", " ", "dead"}], "-", 
