            RowBox[{"{", 
             RowBox[{"0.75", ",", 
              RowBox[{"{", 
               RowBox[{"0.5", ",", "0.5"}], "}"}]}], "}"}]}], "]"}]}]}], 
        "}"}]}], ",", 
      RowBox[{"EdgeShapeFunction", "->", 
       RowBox[{"{", 
        RowBox[{"(*", 
         RowBox[{"Draw", " ", "the", " ", "sweeping", " ", "curves"}], "*)"}], 
        RowBox[{
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
