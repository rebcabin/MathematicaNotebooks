Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{
      "M", "N", "TpM", "TfN", "TpMco", "TfNco"}, {{{1, 2}, {3, 4}, {6, 5}, {1,
        3}, {1, 5}, {2, 4}, {2, 6}}, Null}, {
      EdgeLabels -> {DirectedEdge["M", "N"] -> Placed[
           Style["Map f", 14], {0.5, {0.5, -0.2}}], 
         DirectedEdge["TpM", "TfN"] -> Placed[
           Style["Pushforward \!\(\*SubscriptBox[\(f\), \(*\)]\)", 14], {
           0.5, {0.5, -0.2}}], DirectedEdge["N", "TfN"] -> Placed[
           Framed[
            Style["Tangent Space", 12, 
             GrayLevel[0.4], Bold], FrameStyle -> None, Background -> 
            GrayLevel[1], FrameMargins -> 2], {0.5, {0.5, 0.5}}], 
         DirectedEdge["TfNco", "TpMco"] -> Placed[
           Style["Pullback \!\(\*SuperscriptBox[\(f\), \(*\)]\)", 14], {
           0.5, {0.5, -0.2}}], DirectedEdge["M", "TpM"] -> Placed[
           Framed[
            Style["Tangent Space", 12, 
             GrayLevel[0.4], Bold], FrameStyle -> None, Background -> 
            GrayLevel[1], FrameMargins -> 2], {0.5, {0.5, 0.5}}], 
         DirectedEdge["N", "TfNco"] -> Placed[
           Framed[
            Style["Cotangent Space", 12, 
             GrayLevel[0.4], Bold], FrameStyle -> None, Background -> 
            GrayLevel[1], FrameMargins -> 2], {0.75, {0.5, 0.5}}], 
         DirectedEdge["M", "TpMco"] -> Placed[
           Framed[
            Style["Cotangent Space", 12, 
             GrayLevel[0.4], Bold], FrameStyle -> None, Background -> 
            GrayLevel[1], FrameMargins -> 2], {0.75, {0.5, 0.5}}]}, 
       EdgeShapeFunction -> {
        DirectedEdge["TfNco", "TpMco"] -> 
         GraphComputation`GraphElementData[{
           "FilledArrow", "ArrowSize" -> 0.04}], DirectedEdge["N", "TfNco"] -> 
         GraphComputation`GraphElementData[{
           "CurvedArc", "Curvature" -> -0.8}], DirectedEdge["M", "TpMco"] -> 
         GraphComputation`GraphElementData[{"CurvedArc", "Curvature" -> 0.8}],
          DirectedEdge["M", "N"] -> 
         GraphComputation`GraphElementData[{
           "FilledArrow", "ArrowSize" -> 0.04}], DirectedEdge["TpM", "TfN"] -> 
         GraphComputation`GraphElementData[{
           "FilledArrow", "ArrowSize" -> 0.04}]}, 
       EdgeStyle -> {DirectedEdge["N", "TfNco"] -> Directive[
           Dashing[{0, Small}], 
           GrayLevel[0.5], 
           AbsoluteThickness[4.5], 
           Arrowheads[0]], DirectedEdge["TfNco", "TpMco"] -> Directive[
           GrayLevel[0], 
           AbsoluteThickness[3]], DirectedEdge["N", "TfN"] -> Directive[
           Dashing[{0, Small}], 
           GrayLevel[0.5], 
           AbsoluteThickness[4.5], 
           Arrowheads[0]], DirectedEdge["M", "TpMco"] -> Directive[
           Dashing[{0, Small}], 
           GrayLevel[0.5], 
           AbsoluteThickness[4.5], 
           Arrowheads[0]], DirectedEdge["M", "N"] -> Directive[
           GrayLevel[0], 
           AbsoluteThickness[3]], DirectedEdge["TpM", "TfN"] -> Directive[
           GrayLevel[0], 
           AbsoluteThickness[3]], DirectedEdge["M", "TpM"] -> Directive[
           Dashing[{0, Small}], 
           GrayLevel[0.5], 
           AbsoluteThickness[4.5], 
           Arrowheads[0]]}, ImagePadding -> 60, ImageSize -> 750, 
       VertexCoordinates -> {{0, 2}, {1.3, 2}, {0, 1}, {1.3, 1}, {0, 0}, {
         1.3, 0}}, 
       VertexLabels -> {
        "N" -> Placed["Manifold N", Center], "TpM" -> 
         Placed["\!\(\*SubscriptBox[\(T\), \(p\)]\)M (Vectors)", Center], "M" -> 
         Placed["Manifold M", Center], "TfNco" -> 
         Placed["\!\(\*SubsuperscriptBox[\(T\), \(f(p)\), \(*\)]\)N \
(Covectors)", Center], "TpMco" -> 
         Placed["\!\(\*SubsuperscriptBox[\(T\), \(p\), \(*\)]\)M (Covectors)",
            Center], "TfN" -> 
         Placed["\!\(\*SubscriptBox[\(T\), \(f(p)\)]\)N (Vectors)", Center]}, 
       VertexLabelStyle -> {
         Directive[
          GrayLevel[1], FontFamily -> "Helvetica", 14]}, VertexShapeFunction -> {
         Function[{$CellContext`coord, $CellContext`name, $CellContext`size}, 
          
          If[
           Or[$CellContext`name === "M", $CellContext`name === "N"], {
            RGBColor[0.15, 0.15, 0.25], 
            Disk[$CellContext`coord, Max[$CellContext`size] 1.3]}, {
            RGBColor[0.15, 0.15, 0.25], 
            
            Rectangle[$CellContext`coord - $CellContext`size, \
$CellContext`coord + $CellContext`size]}]]}, 
       VertexSize -> {{"Scaled", 0.18}}}]]}, 
