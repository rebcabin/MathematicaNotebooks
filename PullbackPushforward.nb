          "*)"}], 
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
           RowBox[{"\"\<M\>\"", ",", "\"\<TpMco\>\""}], "]"}], "->", 
          RowBox[{"Placed", "[", 
           RowBox[{
            RowBox[{"strucLabel", "[", "\"\<Cotangent Space\>\"", "]"}], ",", 
            
            RowBox[{"{", 
             RowBox[{"0.75", ",", 
              RowBox[{"{", 
               RowBox[{"0.5", ",", "0.5"}], "}"}]}], "}"}]}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
           RowBox[{"\"\<N\>\"", ",", "\"\<TfNco\>\""}], "]"}], "->", 
