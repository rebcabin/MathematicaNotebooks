        RowBox[{"(*", 
         RowBox[{"Structural", " ", "Associations"}], "*)"}], 
        RowBox[{"DirectedEdge", "[", 
         RowBox[{"\"\<M\>\"", ",", "\"\<TpM\>\""}], "]"}], ",", 
        RowBox[{"DirectedEdge", "[", 
         RowBox[{"\"\<M\>\"", ",", "\"\<TpMco\>\""}], "]"}], ",", 
        RowBox[{"DirectedEdge", "[", 
         RowBox[{"\"\<N\>\"", ",", "\"\<TfN\>\""}], "]"}], ",", 
        RowBox[{"DirectedEdge", "[", 
