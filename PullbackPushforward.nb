Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "geomGraph", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"(*", 
     RowBox[{
     "Helper", " ", "function", " ", "to", " ", "style", " ", "the", " ", 
      "structural", " ", "labels", " ", "with", " ", "a", " ", "white", " ", 
      "background"}], "*)"}], 
    RowBox[{"strucLabel", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"text", ",", 
       RowBox[{"Framed", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"text", ",", "12", ",", 
           RowBox[{"GrayLevel", "[", "0.4", "]"}], ",", "Bold"}], "]"}], ",", 
         
         RowBox[{"FrameStyle", "->", "None"}], ",", 
         RowBox[{"Background", "->", "White"}], ",", 
         RowBox[{"FrameMargins", "->", "2"}]}], "]"}]}], "]"}]}], "}"}], ",", 
   
   RowBox[{"geomGraph", "=", 
    RowBox[{"Graph", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<M\>\"", ",", "\"\<N\>\"", ",", "\"\<TpM\>\"", 
        ",", "\"\<TfN\>\"", ",", "\"\<TpMco\>\"", ",", "\"\<TfNco\>\""}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"(*", 
        RowBox[{"Mathematical", " ", "Maps"}], "*)"}], 
