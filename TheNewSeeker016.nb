Cell[CellGroupData[{

Cell["Wandering: \[CapitalDelta] too Big", "Subsection",
 CellChangeTimes->{{3.7755621499031982`*^9, 
  3.7755621559711733`*^9}},ExpressionUUID->"a76f8541-15b8-43e9-b080-\
3c8d5641bb12"],

Cell["\<\
When \[CapitalDelta] is too big, we never find the target because our search \
doesn't shrink quickly enough. Such trials are \"wandering.\" We can't find \
out about wandering till we actually run out of gas.\
\>", "Text",
 CellChangeTimes->{{3.775402639959318*^9, 3.77540299308497*^9}, {
   3.775403629670733*^9, 3.7754039336643057`*^9}, 3.77540425108463*^9, {
