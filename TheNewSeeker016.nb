Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "vizSeek2D002", ",", "dist", ",", "yp", ",", "\[Sigma]", ",", "cov", ",", 
    "i"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
