Cell[CellGroupData[{

Cell["Searching for Best \[CapitalDelta]", "Chapter",
 CellChangeTimes->{{3.775413676616678*^9, 3.775413683242242*^9}, {
  3.9115744141816807`*^9, 
  3.91157442098074*^9}},ExpressionUUID->"7b03cf13-9551-4762-b29b-\
8dc855a3205d"],

Cell[TextData[{
 "We sweep the the decay ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]", TraditionalForm]],ExpressionUUID->
  "fd5ca442-0428-498a-8014-f1d45a06b8cf"],
 " in an episode, one \[CapitalDelta] in each of 16 rollouts, looking for the \
best \[CapitalDelta] for a given ",
 Cell[BoxData[
  FormBox[
   StyleBox["dim",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "685fbc8e-e165-4258-bc8d-0a07ad8f6c6a"],
 " and ",
 StyleBox["maxIter",
  FontSlant->"Italic"],
 ", the size of the gas tank. For the biggest episode in this notebook, with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "=", "2000"}], TraditionalForm]],ExpressionUUID->
  "90102177-901c-4192-97d4-a24d4d76cf5a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     RowBox[{"gas", " ", "tank"}],
     FontSlant->"Italic"], 
    StyleBox["=",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["maxIter",
      FontSlant->"Italic"], "=", "160000"}]}], TraditionalForm]],
  ExpressionUUID->"db6e0fc1-8d8f-49fe-b3f4-b17d0dbe1c71"],
 ", the best \[CapitalDelta] is ",
 Cell[BoxData[
  FormBox["0.999919", TraditionalForm]],ExpressionUUID->
  "3e0febd1-c34f-446b-862d-65b0fd92eb8c"],
 ". "
}], "Text",
 CellChangeTimes->{{3.775402639959318*^9, 3.77540299308497*^9}, {
   3.775403629670733*^9, 3.7754039336643057`*^9}, 3.77540425108463*^9, {
