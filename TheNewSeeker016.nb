Cell[CellGroupData[{

Cell["Visualization Gadget", "Chapter",
 CellChangeTimes->{{3.775485743562002*^9, 
  3.775485747905395*^9}},ExpressionUUID->"6938a035-958d-4659-a7d8-\
ec86d6aab484"],

Cell[TextData[{
 "With the following visualization, experiment interactively with the \
hyperparameters. Try the various sliders and dimension buttons. \
\[CapitalDelta] is represented by ",
 StyleBox["ld, ",
  FontSlant->"Italic"],
 "its number of leading nines, smaller for smaller \[CapitalDelta] and faster \
decay; ",
 StyleBox["tol",
  FontSlant->"Italic"],
 " and gas tank (number of reps aka ",
 StyleBox["maxIter",
  FontSlant->"Italic"],
 ") are logarithmic. "
}], "Text",
 CellChangeTimes->{{3.7754224531406717`*^9, 3.775422532873396*^9}, {
   3.7754225833971367`*^9, 3.775422586137444*^9}, 3.775479374592556*^9, {
