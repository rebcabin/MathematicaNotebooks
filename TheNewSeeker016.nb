0831602b548b"],

Cell[TextData[{
 "The defaults are set for an easy test, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["dim",
     FontSlant->"Italic"], "=", "2"}], TraditionalForm]],ExpressionUUID->
  "2e3b15e7-9f22-47ec-9bee-39e73e5774c2"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "=", "0.9"}], TraditionalForm]],ExpressionUUID->
  "c8f97730-992e-485f-b7fb-4848d6712688"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        SubscriptBox["log", "10"], "(", 
        RowBox[{"1", "-", "\[CapitalDelta]"}], ")"}]}], 
