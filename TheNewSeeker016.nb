      RowBox[{
      "ld", ",", "1.0", 
       ",", "\"\<-\!\(\*SubscriptBox[\(log\), \
\(10\)]\)(1-\[CapitalDelta])\>\""}], "}"}], ",", "0.", ",", "5.", ",", "0.25",
      ",", 
     RowBox[{"Appearance", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Open\>\"", ",", "\"\<Labeled\>\""}], "}"}]}]}], "}"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "lm", ",", "3", 
       ",", "\"\<\!\(\*SubscriptBox[\(log\), \(10\)]\)(reps)\>\""}], "}"}], ",",
      "0", ",", "7", ",", "1", ",", 
     RowBox[{"Appearance", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Open\>\"", ",", "\"\<Labeled\>\""}], "}"}]}]}], "}"}], ",",
    "\[IndentingNewLine]", 
