RjgvnW2DqvTcLnjg27HAm7sqG3wcVe+A1irFFIxgMz/Bclf9HNTHbnP+dnd/
hffumn1c/9SGH9KK6T/Q+GA8AAWUaw9OP22hdol1gpY46LZ0JUEru5kCaXsg
Dd5RS9OhKeNaExSeKGmGo4+Yh5CJTO2BGT1GGvJPvnkGw17lL+8TA4tDP6Dk
efbsAdF37NscHMhyrAspVhlcPbMBL7klIaHEhhcdp2GFZ7gG6n5KzVBgXbVA
b61xBGqmnCsxxDPU+V8wQasLlhNvvFdEwitlXjHsTz0shZ2G4tfHxaxSEa8e
hV/kCWOwot3C2fBheAK2/5W8g5pJvyma2OHd64WrVNpLOP9P5oaio0EzcEFf
wqmj+VtwS+/a5nS2jl0kXtYw4zAgY2ywtfuqEw7Ykq/nE6ubO/OgZ98UXioh
v+95IpijzSycuOBX2s+uqaGhLfnJWyJTNEjDhbUY20eitiqR8z8W6Tvi
  "],ExpressionUUID->"b7c7e238-b7ba-462c-ac41-5f6249280b3f"],

Cell[TextData[{
 "Call ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 " from ",
 StyleBox["Fold",
  FontSlant->"Italic"],
 " wrapped in three nested ",
 StyleBox["Catches",
  FontSlant->"Italic"],
 ", one for each of \[OpenCurlyDoubleQuote]",
 StyleBox["Found",
  FontSlant->"Italic"],
 ",\[CloseCurlyDoubleQuote] \[OpenCurlyDoubleQuote]",
 StyleBox["Dead",
  FontSlant->"Italic"],
 ",\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]",
 StyleBox["Wandering",
  FontSlant->"Italic"],
 ".\[CloseCurlyDoubleQuote] Optionally, ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 " reaps intermediate results for logging, debugging, and visualization, by \
setting ",
 StyleBox["sow",
  FontSlant->"Italic"],
 " (lower case) to ",
 StyleBox["Sow",
  FontSlant->"Italic"],
 ". ",
 StyleBox["Sow",
  FontSlant->"Italic"],
 " uses memory, so set ",
 StyleBox["sow",
  FontSlant->"Italic"],
 " to ",
 StyleBox["Identity",
  FontSlant->"Italic"],
 " for big runs. Likewise, ",
 StyleBox["deathTest",
  FontSlant->"Italic"],
 " defaults to ",
 StyleBox["True",
  FontSlant->"Italic"],
 "; set it to ",
 StyleBox["False",
  FontSlant->"Italic"],
 " to ",
 StyleBox["measure",
  FontSlant->"Italic"],
 " the \[OpenCurlyDoubleQuote]death tax.\[CloseCurlyDoubleQuote] If the death \
test is too aggressive, you get more wins with ",
 StyleBox["deathTest",
  FontSlant->"Italic"],
 " set to ",
 StyleBox["False",
  FontSlant->"Italic"],
 ", that is, you will \[OpenCurlyDoubleQuote]feel\[CloseCurlyDoubleQuote] the \
\[OpenCurlyDoubleQuote]death tax.\[CloseCurlyDoubleQuote]"
}], "Text",
 CellChangeTimes->{{3.7749736921811666`*^9, 3.7749737365486517`*^9}, {
   3.774973790121737*^9, 3.7749737912813797`*^9}, {3.7749738437315693`*^9, 
   3.774973951625668*^9}, {3.775422097632021*^9, 3.775422143994142*^9}, {
   3.775422188405705*^9, 3.7754222914925423`*^9}, {3.7754793375365047`*^9, 
   3.775479374574136*^9}, {3.775479426771432*^9, 3.775479621091567*^9}, {
   3.77548544772297*^9, 3.775485494979829*^9}, {3.775485548367765*^9, 
   3.775485640771397*^9}, {3.775487749538663*^9, 3.775487781054734*^9}, {
   3.775562360723875*^9, 3.775562427290895*^9}, {3.776108731782135*^9, 
   3.776108848111165*^9}, {3.776112891396907*^9, 3.776113026142726*^9}, {
   3.776113098120977*^9, 3.776113134172789*^9}, 3.91156600337562*^9, {
   3.9115660540553217`*^9, 3.91156605605403*^9}, {3.911574781614932*^9, 
   3.911574824342293*^9}, {3.911574929246117*^9, 3.9115749298341827`*^9}, {
   3.9115975414990788`*^9, 
   3.911597592563333*^9}},ExpressionUUID->"f88a4eeb-9f85-463b-96a1-\
61572a2cabaa"],

Cell[TextData[{
 "The parameters of ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 " are split into two lists, the left list holding the prior state, the right \
list holding inputs for the current call. The output is a new state, so ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 " meets the requirements for ",
 StyleBox["Fold",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.7749736921811666`*^9, 3.7749737365486517`*^9}, {
   3.774973790121737*^9, 3.7749737912813797`*^9}, {3.7749738437315693`*^9, 
   3.774973951625668*^9}, {3.775422097632021*^9, 3.775422143994142*^9}, {
   3.775422188405705*^9, 3.7754222914925423`*^9}, {3.7754793375365047`*^9, 
   3.775479374574136*^9}, {3.775479426771432*^9, 3.775479621091567*^9}, {
   3.77548544772297*^9, 3.775485494979829*^9}, {3.775485548367765*^9, 
   3.775485640771397*^9}, {3.775487749538663*^9, 3.775487781054734*^9}, {
   3.775562360723875*^9, 3.775562427290895*^9}, {3.776108731782135*^9, 
   3.776108848111165*^9}, {3.776112891396907*^9, 3.776113026142726*^9}, {
   3.776113098120977*^9, 3.776113134172789*^9}, 3.91156600337562*^9, {
   3.9115749480378027`*^9, 
   3.911574948620468*^9}},ExpressionUUID->"9bafa1d0-7a32-4b53-940c-\
e42928877c57"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sow", "=", "Sow"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"deathTest", "=", "True"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ClearAll", "[", "doJudgment", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"doJudgment", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"yp_", ",", "dist_", ",", "\[Sigma]_"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\[CapitalDelta]_", ",", "target_", ",", "tol_", ",", "maxIter_", ",", 
       "i_"}], "}"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"deathTest", " ", "&&", " ", 
          RowBox[{"(", 
           RowBox[{"dist", ">", 
            RowBox[{"10", "maxIter", " ", "\[Sigma]"}]}], ")"}]}], ")"}], ",", 
        RowBox[{"Throw", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "yp", ",", "dist", ",", "\[Sigma]", ",", "target", ",", 
            "\[CapitalDelta]", ",", "i"}], "}"}], ",", "\"\<Dead\>\""}], 
         "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "\[GreaterEqual]", "maxIter"}], ",", 
        RowBox[{"Throw", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "yp", ",", "dist", ",", "\[Sigma]", ",", "target", ",", 
            "\[CapitalDelta]", ",", "i"}], "}"}], ",", "\"\<Wandering\>\""}], 
         "]"}]}], "]"}], ";", " ", "\[IndentingNewLine]", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a", "=", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"RandomVariate", "[", 
              RowBox[{"NormalDistribution", "[", 
               RowBox[{"#", ",", "\[Sigma]"}], "]"}], "]"}], "&"}], ",", 
            "yp"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"With", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"da", "=", 
            RowBox[{"EuclideanDistance", "[", 
             RowBox[{"target", ",", "a"}], "]"}]}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"da", "<", "tol"}], ",", 
             RowBox[{"Throw", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                "a", ",", "da", ",", "\[Sigma]", ",", "target", ",", 
                 "\[CapitalDelta]", ",", "i"}], "}"}], ",", "\"\<Found\>\""}],
               "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"b", "=", 
               RowBox[{"Map", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"RandomVariate", "[", 
                   RowBox[{"NormalDistribution", "[", 
                    RowBox[{"#", ",", "\[Sigma]"}], "]"}], "]"}], "&"}], ",", 
                 "yp"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{"With", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"db", "=", 
                 RowBox[{"EuclideanDistance", "[", 
                  RowBox[{"target", ",", "b"}], "]"}]}], "}"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"db", "<", "tol"}], ",", 
                  RowBox[{"Throw", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    "b", ",", "db", ",", "\[Sigma]", ",", "target", ",", 
                    "\[CapitalDelta]", ",", "i"}], "}"}], 
                    ",", "\"\<Found\>\""}], "]"}]}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"With", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"\[Nu]\[Sigma]", "=", 
                    RowBox[{"Quiet", "[", 
                    RowBox[{"\[Sigma]", "*", "\[CapitalDelta]"}], "]"}]}], 
                   "}"}], ",", "\[IndentingNewLine]", 
                  RowBox[{"sow", "@", 
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"da", "<", "db"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "da", ",", "\[Nu]\[Sigma]"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"b", ",", "db", ",", "\[Nu]\[Sigma]"}], "}"}]}], 
                    "]"}]}]}], "]"}]}]}], "]"}]}], "]"}]}]}], "]"}]}], 
       "]"}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.774860811987418*^9, 3.774860853623076*^9}, {
   3.774860888991786*^9, 3.774860949063779*^9}, {3.7748610096522493`*^9, 
   3.77486107036479*^9}, {3.774861100633987*^9, 3.774861145966061*^9}, {
   3.774861849555876*^9, 3.774861879254299*^9}, {3.774861928264978*^9, 
   3.774862065810011*^9}, {3.7748621044704113`*^9, 3.774862165559668*^9}, {
   3.774862238297935*^9, 3.774862274907572*^9}, {3.7748623087403793`*^9, 
   3.774862429789135*^9}, {3.7748625063034697`*^9, 3.774862532458838*^9}, {
   3.774869195588398*^9, 3.774869203276643*^9}, {3.774873498692444*^9, 
   3.774873500587491*^9}, {3.774873598761982*^9, 3.774873649835025*^9}, {
   3.774875170559164*^9, 3.774875231995968*^9}, {3.7748803453676023`*^9, 
   3.774880353943447*^9}, {3.774881027598523*^9, 3.7748810530937433`*^9}, {
   3.774882147795711*^9, 3.774882159073484*^9}, {3.7748821934853983`*^9, 
   3.774882423021537*^9}, {3.77489453491426*^9, 3.774894543038209*^9}, {
   3.774894599777317*^9, 3.774894601654038*^9}, {3.774894643703484*^9, 
   3.774894693366374*^9}, {3.774899583129816*^9, 3.774899585133382*^9}, {
   3.774900935803741*^9, 3.774900937494644*^9}, {3.774901842248197*^9, 
   3.774901844197834*^9}, {3.774914453162562*^9, 3.774914459689188*^9}, {
   3.77491474973446*^9, 3.774914754708432*^9}, {3.77491480304748*^9, 
   3.774914803362211*^9}, 3.7749148804854*^9, {3.7749149844283323`*^9, 
   3.7749149875191383`*^9}, {3.774915093506249*^9, 3.774915093675971*^9}, {
   3.77491607263166*^9, 3.774916088616705*^9}, {3.774970228557085*^9, 
   3.77497024803517*^9}, {3.7750439893301783`*^9, 3.775043992538512*^9}, {
   3.7750545531307583`*^9, 3.7750545552619762`*^9}, 3.7750546184686193`*^9, {
   3.7753118808901033`*^9, 3.775311931148144*^9}, {3.775422326782778*^9, 
   3.775422343660181*^9}, {3.7754793745791893`*^9, 3.775479398650551*^9}, {
   3.7754847990793552`*^9, 3.775484926652576*^9}, {3.775485520831031*^9, 
   3.7754855328258133`*^9}, {3.775485690957654*^9, 3.775485703674402*^9}, {
   3.7759126681123247`*^9, 3.775912721382873*^9}, {3.775912757545113*^9, 
   3.775912904586632*^9}, 3.776084134649208*^9, {3.776104604103524*^9, 
   3.776104604562381*^9}, {3.911566539001861*^9, 3.911566563612802*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"c520dc2a-7c24-430e-8c8d-d91f0c92a3fd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Convenient Form for Output", "Subsection",
 CellChangeTimes->{{3.775478789359707*^9, 
  3.7754787956573677`*^9}},ExpressionUUID->"0990679e-00c5-4065-927f-\
9cb0c366c7cf"],

Cell[TextData[{
 "The following converts outputs from machine-convenient, position-sensitive \
list form to human-convenient ",
 StyleBox["Association",
  FontSlant->"Italic"],
 " form (like ",
 StyleBox["dictionary",
  FontSlant->"Italic"],
 " in Python)."
}], "Text",
 CellChangeTimes->{{3.77542236199862*^9, 3.7754223809793797`*^9}, {
  3.77542241488418*^9, 3.775422426000986*^9}, {3.775485715209297*^9, 
  3.7754857257385406`*^9}},ExpressionUUID->"7be67d4e-1ac3-4e46-aaa8-\
db552d73b074"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "trialDict", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"trialDict", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "yp_", ",", "dist_", ",", "\[Sigma]_", ",", "tar_", ",", 
       "\[CapitalDelta]_", ",", "i_"}], "}"}], ",", "tag_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<yp\>\"", "\[Rule]", "yp"}], ",", 
     RowBox[{"\"\<dist\>\"", "\[Rule]", "dist"}], ",", 
     RowBox[{"\"\<\[Sigma]\>\"", "\[Rule]", "\[Sigma]"}], ",", 
     RowBox[{"\"\<tar\>\"", "\[Rule]", "tar"}], ",", 
     RowBox[{"\"\<\[CapitalDelta]\>\"", "\[Rule]", "\[CapitalDelta]"}], ",", 
     RowBox[{"\"\<i\>\"", "\[Rule]", "i"}], ",", 
     RowBox[{"\"\<tag\>\"", "\[Rule]", "tag"}]}], "|>"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.774882831562634*^9, 3.7748829025756598`*^9}, {
  3.774882955347742*^9, 3.774882976624661*^9}, {3.774903014173609*^9, 
  3.774903024510894*^9}, {3.776113156738017*^9, 3.776113160324505*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"8908a044-29aa-4bdd-879b-851a85bb1bdf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Global Constants Timing Test", "Subsection",
 CellChangeTimes->{{3.776107708086944*^9, 3.7761077105630302`*^9}, {
  3.91156647056996*^9, 
  3.911566479929141*^9}},ExpressionUUID->"4918761d-59de-413c-bc00-\
befa8ada5002"],

Cell["\<\
With constants in the update, we don\[CloseCurlyQuote]t need global variables \
and the code is cleaner. However, it might be expensive to copy constants \
just for convenience. The following shows that the difference in timing is \
NOT significant.\
\>", "Text",
 CellChangeTimes->{
  3.776108858287588*^9, {3.7761092434719887`*^9, 3.776109266775538*^9}, {
   3.776109321989213*^9, 3.776109327235024*^9}, {3.776113186912784*^9, 
   3.776113205973407*^9}},ExpressionUUID->"8368182c-b22b-4e67-93fb-\
8fd7c7b5f280"],

Cell[CellGroupData[{

Cell["Copying Constants into Every Update", "Subsubsection",
 CellChangeTimes->{{3.776109276567774*^9, 
  3.7761092851402197`*^9}},ExpressionUUID->"8fff1679-8568-4d8d-b983-\
02af3c4c5c7e"],

Cell[TextData[{
 "The ",
 StyleBox["With",
  FontSlant->"Italic"],
 " expression introduces constants into its scope."
}], "Text",
 CellChangeTimes->{{3.77611328942832*^9, 
  3.77611330795376*^9}},ExpressionUUID->"336b04df-db5e-44f4-9875-\
41ea42ce7eb3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"result", "=", "\[IndentingNewLine]", 
     RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox[
           RowBox[{"sow", "=", "Identity"}],
           Background->RGBColor[1, 1, 0]], ",", 
          RowBox[{"dim", "=", "200"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"With", "[", 
         RowBox[{
          RowBox[{"{", 
           StyleBox[
            RowBox[{
             RowBox[{"tar", "=", 
              RowBox[{"getTarget", "[", "dim", "]"}]}], ",", 
             RowBox[{"tol", "=", "0.01"}], ",", 
             RowBox[{"maxIter", "=", "20000"}]}],
            Background->RGBColor[1, 1, 0]], "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Reap", "[", 
           RowBox[{"Catch", "[", 
            RowBox[{
             RowBox[{"Catch", "[", 
              RowBox[{
               RowBox[{"Catch", "[", 
                RowBox[{
                 RowBox[{"Fold", "[", 
                  StyleBox["\[IndentingNewLine]",
                   Background->RGBColor[1, 1, 0]], 
                  RowBox[{
                   StyleBox["doJudgment",
                    Background->RGBColor[0.87, 0.94, 1]], ",", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"ConstantArray", "[", 
                    RowBox[{"0", ",", "dim"}], "]"}], ",", "0", ",", "1"}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                   StyleBox[
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    "0.9993", ",", "tar", ",", "tol", ",", "maxIter", ",", 
                    "i"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", "maxIter"}], "}"}]}], "]"}],
                    Background->RGBColor[1, 1, 0]]}], "]"}], ",", 
                 "\[IndentingNewLine]", "\"\<Found\>\"", ",", "trialDict"}], 
                "]"}], ",", "\"\<Dead\>\"", ",", "trialDict"}], "]"}], 
             ",", "\"\<Wandering\>\"", ",", "trialDict"}], "]"}], "]"}]}], 
         "]"}]}], "]"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"result", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"result", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}], "[", "\"\<tag\>\"", "]"}], ",", 
     RowBox[{
      RowBox[{"result", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}], "[", "\"\<i\>\"", "]"}]}], 
    "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.776107784271812*^9, 3.7761080436923847`*^9}, {
  3.776108076651054*^9, 3.776108134245851*^9}, {3.77610899081773*^9, 
  3.776109020704982*^9}, {3.776109154721858*^9, 3.776109162354393*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"69495bea-dbc6-4b85-b232-3524d3bd5b5b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.641489`", ",", "\<\"Found\"\>", ",", "14679"}], "}"}]], "Output",\

