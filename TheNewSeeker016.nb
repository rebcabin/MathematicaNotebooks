Cell[TextData[{
 "Iterate steps ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "\[Rule]", "11"}], TraditionalForm]],ExpressionUUID->
  "1755bfaa-38f9-4964-bdec-a723e76afe87"],
 " with a fast, functional ",
 StyleBox["fold",
  FontSlant->"Italic"],
 ". ",
 StyleBox["Fold",
  FontSlant->"Italic"],
 " goes by the Python name ",
 StyleBox["reduce",
  FontSlant->"Italic"],
 " or by the C# name ",
 StyleBox["Aggregate",
  FontSlant->"Italic"],
 ". Fold revises estimates by internally iterating over updates. Fold is a \
function of three arguments: (1) a binary function that converts a state and \
an update into a new state; (2) an initial state value; and (3) a sequence of \
updates. "
}], "Text",
 CellChangeTimes->{{3.775421269105109*^9, 3.775421481137748*^9}, {
  3.775479001093644*^9, 3.775479095728797*^9}, {3.775485266486783*^9, 
  3.775485276753077*^9}, {3.775562185361923*^9, 3.775562201603599*^9}, {
  3.776085104234823*^9, 3.776085104235086*^9}, {3.7760851894164963`*^9, 
  3.7760851894168*^9}, {3.776085318996725*^9, 3.776085318996985*^9}, {
  3.776092355627722*^9, 3.776092367643549*^9}, {3.77609295730777*^9, 
  3.7760929578754387`*^9}, {3.7760930265484657`*^9, 3.776093056162739*^9}, {
  3.776093111870714*^9, 3.776093188808093*^9}, {3.776093395382042*^9, 
  3.7760934646511593`*^9}, {3.776107130599979*^9, 3.776107165319867*^9}, {
  3.776107206256982*^9, 3.776107283007873*^9}, {3.9115740268199253`*^9, 
  3.911574046050646*^9}, {3.911597351245441*^9, 
  3.911597383614205*^9}},ExpressionUUID->"5de3c512-c34e-45fe-87c3-\
14fa1282115c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Fold", 
   RowBox[{"(", 
    RowBox[{
    "binaryFunction", ",", " ", "initialState", ",", " ", 
     "sequenceOfUpdates"}], ")"}]}], " ", "=", " ", 
  RowBox[{
   FormBox[
    RowBox[{"do", " ", 
     RowBox[{"{", 
      RowBox[{"state", "\[LeftArrow]", 
       RowBox[{"binaryFunction", "(", 
        RowBox[{"state", ",", " ", "update"}], ")"}]}], "}"}]}],
    TraditionalForm], " ", "for", " ", "every", " ", "update", " ", "in", " ", 
   RowBox[{"updates", "."}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.7760929744130907`*^9, 3.776093021680355*^9}, {
  3.7760930673830853`*^9, 3.7760931003439913`*^9}, {3.776093475237699*^9, 
  3.776093492653899*^9}, {3.776095008867025*^9, 3.776095043097435*^9}, {
  3.776095124793445*^9, 3.77609512621082*^9}, {3.7761072971764803`*^9, 
  3.776107317962872*^9}},ExpressionUUID->"a3f12f81-2204-4b5b-9eed-\
dc19cc6aadf9"],

Cell[TextData[{
 "In our particular case, we are folding over the binary function",
 StyleBox[" seek,",
  FontSlant->"Italic"],
 " whose two inputs are each tuples:"
}], "Text",
 CellChangeTimes->{{3.7760935009849567`*^9, 
  3.776093536000543*^9}},ExpressionUUID->"43be53cb-3d1c-4372-9cb1-\
f130dac0cbba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Fold", 
   FormBox[
    RowBox[{"(", 
     RowBox[{"seek", ",", 
      RowBox[{"initialState", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          SubscriptBox["y", "p"], "=", 
          SubscriptBox[
           RowBox[{"{", "0", "}"}], 
           SuperscriptBox["\[DoubleStruckCapitalR]", "d"]]}], ",", 
         RowBox[{
          StyleBox["dist",
           FontSlant->"Italic"], "=", "0"}], ",", 
         RowBox[{"\[Sigma]", "=", "1"}]}], "}"}]}], ",", 
      RowBox[{"updates", ":", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[CapitalDelta]", ",", 
           StyleBox["target",
            FontSlant->"Italic"], ",", 
           StyleBox["tol",
            FontSlant->"Italic"], ",", 
           StyleBox["maxIter",
            FontSlant->"Italic"], ",", "i"}], "}"}], " ", "for", " ", "i", " ",
          "in", " ", 
         RowBox[{"Range", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            StyleBox["maxIter",
             FontSlant->"Italic"]}], "}"}], "]"}]}], "]"}]}]}], ")"}],
    TraditionalForm]}], ",", " ", "\n", 
  RowBox[{
   FormBox[
    RowBox[{"=", 
     RowBox[{"do", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          SubscriptBox["y", "p"], ",", 
          StyleBox["dist",
           FontSlant->"Italic"], ",", 
          SubscriptBox["\[Sigma]", "p"]}], "}"}], "\[LeftArrow]", 
        RowBox[{"seek", "(", 
         RowBox[{
          RowBox[{
           StyleBox["state",
            FontSlant->"Italic"], ":", 
           RowBox[{"{", 
            RowBox[{
             SubscriptBox["y", "p"], ",", 
             StyleBox["dist",
              FontSlant->"Italic"], ",", 
             SubscriptBox["\[Sigma]", "p"]}], "}"}]}], ",", 
          RowBox[{
           StyleBox["update",
            FontSlant->"Italic"], ":", 
           RowBox[{"{", 
            RowBox[{"\[CapitalDelta]", ",", 
             StyleBox["target",
              FontSlant->"Italic"], ",", 
             StyleBox["tol",
              FontSlant->"Italic"], ",", 
             StyleBox["maxIter",
              FontSlant->"Italic"], ",", "i"}], "}"}]}]}], ")"}]}], "}"}]}]}],
    
    TraditionalForm], " ", "for", " ", 
   FormBox["i",
    TraditionalForm], " ", "from", " ", "1", " ", "to", " ", 
   RowBox[{
    StyleBox["maxIter",
     FontSlant->"Italic"], "."}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.7760924226834507`*^9, 3.776092522623464*^9}, {
  3.7760925718512173`*^9, 3.776092590697144*^9}, {3.776092653919053*^9, 
  3.7760926555591507`*^9}, {3.776092703218968*^9, 3.776092757431149*^9}, {
  3.776094246972742*^9, 3.776094294627249*^9}, {3.776094741635635*^9, 
  3.776094856362116*^9}, {3.7760948901425047`*^9, 3.776094923896263*^9}, {
  3.7760950553713284`*^9, 3.77609505537246*^9}, {3.776095112104473*^9, 
  3.776095119390379*^9}, {3.776095155901243*^9, 3.776095171111163*^9}, {
  3.776107338556076*^9, 
  3.776107356880525*^9}},ExpressionUUID->"451579d4-5c21-445f-acc4-\
3b9ec0154c41"],

Cell[TextData[{
 "This form iteratively replaces the tuple containing the ",
 StyleBox["current",
  FontSlant->"Italic"],
 " state estimate with a new tuple, driven by the ",
 StyleBox["update",
  FontSlant->"Italic"],
 " tuple, which contains constants ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"\[CapitalDelta]", ",", 
     StyleBox["target",
      FontSlant->"Italic"], ",", 
     StyleBox["tol",
      FontSlant->"Italic"], ",", 
     StyleBox["maxIter",
      FontSlant->"Italic"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "87da5742-75b9-420b-8b81-2df3fac0ff3b"],
 " and one variable, ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "26835560-c1ca-4881-8763-cd1276b2bde7"],
 ". We put the constants in the update tuple to avoid pulling them from the \
global environment. We test whether that choice, which might make a lot of \
copies of the constants, is too costly below."
}], "Text",
 CellChangeTimes->{{3.7760927240900917`*^9, 3.776092731262061*^9}, {
  3.77609277226439*^9, 3.776092933080428*^9}, {3.776095192490542*^9, 
  3.7760952723873377`*^9}, {3.7761073661949463`*^9, 3.7761074008270206`*^9}, {
  3.9115651900269747`*^9, 3.911565191046729*^9}, {3.911574079710463*^9, 
  3.911574097183052*^9}, {3.911574654604865*^9, 
  3.9115746691179037`*^9}},ExpressionUUID->"171caac0-709e-4a22-ad7a-\
666833869fa0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Sampling", "Chapter",
 CellChangeTimes->{{3.774390990039772*^9, 3.774390996425571*^9}, {
  3.7743920247017727`*^9, 
  3.774392027039051*^9}},ExpressionUUID->"147fb181-343c-49ab-b76c-\
01a61ca45262"],

Cell[CellGroupData[{

Cell[TextData[{
 "Uniformly in the ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "0e073251-5b84-404c-aaa2-1e264af4f5a5"],
 "-Ball"
}], "Subsection",
 CellChangeTimes->{{3.7743920554567137`*^9, 3.774392071694015*^9}, {
  3.774426848167026*^9, 3.774426863912149*^9}, {3.774426897922648*^9, 
  3.774426898760784*^9}, {3.774426973204846*^9, 3.77442697676904*^9}, {
  3.775484669572012*^9, 3.775484688064146*^9}, {3.906553127877109*^9, 
  3.906553129399723*^9}},ExpressionUUID->"2a73951e-10e1-4611-aefa-\
3d2f5087f44b"],

Cell[TextData[{
 "This algorithm exploits Archimedes\[CloseCurlyQuote]s \
\[OpenCurlyDoubleQuote]hat-box\[CloseCurlyDoubleQuote] theorem and is the \
fastest known (see https://community.wolfram.com/groups/-/m/t/3081911\
\[InvisibleSpace]). By default, it generates 50,000 uniformly random vectors \
in 2 dimensions, but it works quickly in any number of dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{">=", "2"}], TraditionalForm]],ExpressionUUID->
  "61e92f1c-7cb6-442b-9e0d-6c6292ac0b1f"],
 "."
}], "Text",
 CellChangeTimes->{{3.775421500260041*^9, 3.775421534105068*^9}, {
  3.7754217108633204`*^9, 3.775421786571361*^9}, {3.775562228520804*^9, 
  3.77556222956989*^9}, {3.911565253244979*^9, 3.911565263359242*^9}, {
  3.911597425681315*^9, 
  3.911597463406445*^9}},ExpressionUUID->"6d475aa8-7228-47b6-a0d0-\
cd5875e857b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "uniformInBall", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"uniformInDball", "[", 
    RowBox[{
     RowBox[{"n_", ":", "50000"}], ",", 
     RowBox[{"d_", ":", "2"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Drop", "[", 
      RowBox[{"#", ",", "2"}], "]"}], "&"}], "/@", "\[IndentingNewLine]", 
    RowBox[{"Normalize", "/@", "\[IndentingNewLine]", 
     RowBox[{"RandomVariate", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", 
         RowBox[{"d", "+", "2"}]}], "}"}]}], "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.774391007182806*^9, 3.774391035779409*^9}, {
   3.774391223746627*^9, 3.774391313140318*^9}, {3.774391373789689*^9, 
   3.774391375940106*^9}, {3.774391466771317*^9, 3.7743914840648537`*^9}, 
   3.775484726085907*^9, 3.776112768301691*^9},
 CellLabel->"In[6]:=",ExpressionUUID->"caee1a4f-5319-41a8-9d93-ab4ddcbb8538"],

Cell["There follows a visual demonstration of uniformity. ", "Text",
 CellChangeTimes->{{3.775421549704047*^9, 3.775421556417589*^9}, {
  3.775421678028576*^9, 
  3.7754216805101*^9}},ExpressionUUID->"8a78bf8b-e368-41fd-acda-91c39cf237f9"],

Cell[CellGroupData[{

