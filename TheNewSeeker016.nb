   3.9725484860432167`*^9},ExpressionUUID->"95b34f0d-1a88-432f-b367-\
1a6d453b56cd"],

Cell[TextData[{
 "A harder test is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["dim",
     FontSlant->"Italic"], "=", "200"}], TraditionalForm]],ExpressionUUID->
  "07c53241-ef01-4fa6-be55-e275050bbaa4"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "=", "0.999483"}], TraditionalForm]],
  ExpressionUUID->"2d11ebc4-30a1-4bfe-9b09-956c57cdeed1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"-", 
      RowBox[{
       SubscriptBox["log", "10"], "(", 
       RowBox[{"1", "-", "\[CapitalDelta]"}], ")"}]}], ")"}], "\[TildeTilde]",
     " ", 
    FormBox["3.25",
     TraditionalForm]}], TraditionalForm]],ExpressionUUID->
  "4e459eb4-0c7a-4c1f-95a9-6904ca5ca323"],
 "; number of reps = ",
 Cell[BoxData[
  FormBox["100000", TraditionalForm]],ExpressionUUID->
  "eadaacdd-8236-4905-8dac-032c801c551b"],
 "; -2, 3.25, 5, 2, 200 for the controls from top to bottom. It might take a \
while to draw the picture. It succeeds most of the time after about ",
 Cell[BoxData[
  FormBox["17500", TraditionalForm]],ExpressionUUID->
  "78d48766-ca5e-4221-9047-b4f3abde033f"],
 " judgments. Be patient. If you get ",
 StyleBox["$Aborted",
  FontSlant->"Italic"],
 ", press the DO AGAIN button and wait a little. "
}], "Text",
 CellChangeTimes->{{3.7754224531406717`*^9, 3.775422532873396*^9}, {
   3.7754225833971367`*^9, 3.775422586137444*^9}, 3.775479374592556*^9, {
