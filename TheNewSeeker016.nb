  "e4553e54-32c7-45a2-80af-86d5445ee923"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"number", " ", "of", " ", "reps"}], "=", "100"}], 
   TraditionalForm]],ExpressionUUID->"2589fec2-3b7a-4129-8f74-8cb7257145f2"],
 "; -2, 1, 2, 2, 2 for the controls from top to bottom. This draws quickly \
enough that you can press the DO AGAIN button at will. "
}], "Text",
 CellChangeTimes->{{3.7754224531406717`*^9, 3.775422532873396*^9}, {
   3.7754225833971367`*^9, 3.775422586137444*^9}, 3.775479374592556*^9, {
