Cell[CellGroupData[{

Cell["Do One Judgment", "Subsection",
 CellChangeTimes->{{3.775479634889491*^9, 
  3.775479639979993*^9}},ExpressionUUID->"a68ab842-f026-44b5-a42c-\
f9e0d5cada12"],

Cell[TextData[{
 "The following function, ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 ", performs one judgment. It throws when it dies, or wins within tolerance \
",
 StyleBox["tol",
  FontSlant->"Italic"],
 ", or runs out of gas wandering. The caller of ",
 StyleBox["doJudgment",
  FontSlant->"Italic"],
 " handles all returns in ",
 StyleBox["Catch",
  FontSlant->"Italic"],
 " blocks. "
}], "Text",
 CellChangeTimes->CompressedData["
1:eJwdzVtIU3EAx/G1hy6LNJtkaq6zFXPkZTJNS0mcqBglOB3ig44Uk42J81ZO
KxGnznA9GIShB0sUC7pMDgpO2iVYNZNs4oXWQ1qIkJ55iYh5o/6/8/Dj8/KD
