Cell[CellGroupData[{

Cell["Conclusion: 2000 Dimensions", "Chapter",
 CellChangeTimes->{{3.775505128176366*^9, 3.775505131132268*^9}, {
  3.775505327882461*^9, 
  3.7755053299360723`*^9}},ExpressionUUID->"999f4b76-29b6-4cab-b8ef-\
82d427315e39"],

Cell[TextData[{
 "This last graph is the jewel of this notebook. It takes at least six hours \
to run, but shows that we can find the needle in the haystack most of the \
time if we set \[CapitalDelta] and ",
 Cell[BoxData[
  FormBox[
   StyleBox["maxIter",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "85e93c34-ddc0-415f-8146-11c6fce8505b"],
 " well, specifically to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "=", "0.999919"}], TraditionalForm]],
  ExpressionUUID->"6a1209e0-1c36-47fa-b826-89a145494a53"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["maxIter",
     FontSlant->"Italic"], "=", "160000"}], TraditionalForm]],ExpressionUUID->
  "ec55d33e-ae73-4b03-882e-c65544bf479a"],
 ", though it took several trial-and-error runs to find the appropriate range \
of \[CapitalDelta]s to sweep. It demonstrates that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", if appropriately programmed with fast and elegant functional forms, can \
run challenging numerical experiments. "
}], "Text",
 CellChangeTimes->{{3.7755051485901814`*^9, 3.775505388395143*^9}, {
  3.775993817657189*^9, 3.775993880753479*^9}, {3.776176146051956*^9, 
  3.776176147006749*^9}, {3.91159856115184*^9, 3.9115985648883944`*^9}, {
  3.972548811704101*^9, 
  3.972548811894723*^9}},ExpressionUUID->"22afa4e7-0c49-4db1-9505-\
2dc6e990cec9"],

Cell[CellGroupData[{

