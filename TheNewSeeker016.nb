a22a9f3378a8"],

Cell[TextData[{
 "We predict we\[CloseCurlyQuote]ll run out of gas when the distance of the \
current estimate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "p"], TraditionalForm]],ExpressionUUID->
  "51b2f46f-c365-4184-9829-f0803ed2d5c9"],
 " from the true target is greater than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"10", "\[Times]", 
    StyleBox["maxIter",
     FontSlant->"Italic"], "\[Times]", 
    SubscriptBox["\[Sigma]", "p"]}], TraditionalForm]],ExpressionUUID->
  "e0842df5-96b0-427e-9ec7-17f4032ec916"],
 ". We predict, right or wrong, that we're not going to get within ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "p"], TraditionalForm]],ExpressionUUID->
  "d61d4dbc-7e0b-4058-8a11-4f5b3f4d3415"],
 " of the target in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"10", "\[Times]", 
    StyleBox["maxIter",
     FontSlant->"Italic"]}], TraditionalForm]],ExpressionUUID->
  "4d9227e0-2f52-4dc2-8e46-82c8bfd15975"],
 " more judgments even if we weren't shrinking ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "p"], TraditionalForm]],ExpressionUUID->
  "e8c0f6ed-0321-432e-99da-d3b0d6c42ea8"],
 ". We don't have enough gas by an order of magnitude. We call such a trial \
\"dead.\" This death-prediction formula, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"10", "\[Times]", 
    StyleBox["maxIter",
     FontSlant->"Italic"], "\[Times]", 
    SubscriptBox["\[Sigma]", "p"]}], TraditionalForm]],ExpressionUUID->
  "8da667bf-bcde-4fa5-95f0-3c15dfec5b65"],
 ", is just a heuristic. We might find a better heuristic by thinking harder \
or by doing more trial-and-error tuning."
}], "Text",
 CellChangeTimes->{{3.775402639959318*^9, 3.77540299308497*^9}, {
   3.775403629670733*^9, 3.7754039336643057`*^9}, 3.77540425108463*^9, {
