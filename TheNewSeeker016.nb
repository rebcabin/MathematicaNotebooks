Cell[CellGroupData[{

Cell["Fast Incremental Statistics", "Subsection",
 CellChangeTimes->{{3.775486702668501*^9, 3.775486712545308*^9}, {
  3.776113887962041*^9, 
  3.7761138919311743`*^9}},ExpressionUUID->"3c07d23c-ee6f-4b53-b193-\
7d6544c2bdbc"],

Cell[TextData[{
 "The following are fast incremental statistics in constant memory. See ",
 ButtonBox["http://vixra.org/abs/1606.0328",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://vixra.org/abs/1606.0328"], None},
  ButtonNote->"http://vixra.org/abs/1606.0328"],
 ". We need them to assess success rates and thus the \
\[OpenCurlyDoubleQuote]death tax.\[CloseCurlyDoubleQuote]"
}], "Text",
 CellChangeTimes->{{3.7754226285026197`*^9, 3.775422680971011*^9}, {
  3.7754876157882023`*^9, 3.7754876327887783`*^9}, {3.775487666425014*^9, 
  3.7754876692798147`*^9}, {3.776113882672789*^9, 
  3.776113894822112*^9}},ExpressionUUID->"5ab6b823-4836-4d6d-b09a-\
74c63c9c91be"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"cume", ",", "zeroStats"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zeroStats", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<mean\>\"", "\[Rule]", "0"}], ",", 
     RowBox[{"\"\<min\>\"", "\[Rule]", "Infinity"}], ",", 
     RowBox[{"\"\<max\>\"", "\[Rule]", 
      RowBox[{"-", "Infinity"}]}], ",", 
     RowBox[{"\"\<var\>\"", "\[Rule]", "0"}], ",", 
     RowBox[{"\"\<n\>\"", "\[Rule]", "0"}], ",", 
     RowBox[{"\"\<stddev\>\"", "\[Rule]", "0"}]}], "|>"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cume", "[", 
    RowBox[{"runningStats_", ",", "z_"}], "]"}], ":=", "\[IndentingNewLine]", 
   
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"runningStats", "[", "\"\<mean\>\"", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"max", "=", 
        RowBox[{"runningStats", "[", "\"\<max\>\"", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"min", "=", 
        RowBox[{"runningStats", "[", "\"\<min\>\"", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"runningStats", "[", "\"\<n\>\"", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"var", "=", 
        RowBox[{"runningStats", "[", "\"\<var\>\"", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"K", "=", 
          FractionBox["1.", 
           RowBox[{"n", "+", "1."}]]}], ",", 
         RowBox[{"r", "=", 
          RowBox[{"z", "-", "m"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"var2", "=", 
           FractionBox[
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"n", "-", "1"}], ")"}], "var"}], "+", 
             RowBox[{"K", " ", "n", " ", 
              SuperscriptBox["r", "2"]}]}], 
            RowBox[{"Max", "[", 
             RowBox[{"1", ",", "n"}], "]"}]]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<mean\>\"", "\[Rule]", 
            RowBox[{"m", "+", 
             RowBox[{"K", " ", "r"}]}]}], ",", 
           RowBox[{"\"\<n\>\"", "\[Rule]", 
            RowBox[{"n", "+", "1"}]}], ",", 
           RowBox[{"\"\<min\>\"", "\[Rule]", 
            RowBox[{"Min", "[", 
             RowBox[{"z", ",", "min"}], "]"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"\"\<max\>\"", "\[Rule]", 
            RowBox[{"Max", "[", 
             RowBox[{"z", ",", "max"}], "]"}]}], ",", 
           RowBox[{"\"\<var\>\"", "\[Rule]", "var2"}], ",", 
           RowBox[{"\"\<stddev\>\"", "\[Rule]", 
            RowBox[{"Sqrt", "[", "var2", "]"}]}]}], "|>"}]}], "]"}]}], 
      "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"FoldList", "[", 
    RowBox[{"cume", ",", "zeroStats", ",", 
     RowBox[{"{", 
      RowBox[{"55", ",", "89", ",", "144"}], "}"}]}], "]"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.774873676837759*^9, 3.774873757693515*^9}, {
   3.7748737924659224`*^9, 3.7748742836678553`*^9}, {3.774874320495668*^9, 
   3.7748743488943977`*^9}, {3.774874470950288*^9, 3.7748744751199903`*^9}, {
   3.774874553406612*^9, 3.7748746220594177`*^9}, {3.774874667134272*^9, 
   3.774874693816904*^9}, {3.774874781822411*^9, 3.774874888477104*^9}, {
   3.774881657964094*^9, 3.774881726978467*^9}, 3.774901143783022*^9},
 CellLabel->"In[32]:=",ExpressionUUID->"6f981ad6-6df1-4217-9b27-44608149a2e7"],

Cell[TextData[{
 "A bunch of rollouts is an episode. ",
 StyleBox["doEpisode",
  FontSlant->"Italic"],
 " depends on ",
 StyleBox["trial",
  FontSlant->"Italic"],
 " defined above. It introduces another hyperparameter, ",
 StyleBox["maxRol",
  FontSlant->"Italic"],
 ", the number of rollouts in an episode. In this notebook, we leave it at \
100. "
}], "Text",
 CellChangeTimes->{{3.775040821033205*^9, 3.775040849084161*^9}, {
   3.77547832904923*^9, 3.775478357225422*^9}, {3.775478393555599*^9, 
   3.775478395135687*^9}, {3.775486859160512*^9, 3.775486862012014*^9}, {
   3.7754879229055443`*^9, 3.775487937038392*^9}, {3.7754879755873327`*^9, 
   3.7754880686839523`*^9}, {3.775488253761981*^9, 3.775488268310772*^9}, {
   3.775488725413525*^9, 3.775488830029674*^9}, {3.775488874078895*^9, 
   3.7754888768254557`*^9}, {3.7754889584691668`*^9, 3.775488961043726*^9}, {
   3.775489290270294*^9, 3.775489373116015*^9}, {3.775489770591716*^9, 
   3.775489801889936*^9}, {3.7761139687072372`*^9, 3.776114025104475*^9}, {
   3.776114059643524*^9, 3.776114135329883*^9}, {3.911577312759233*^9, 
   3.911577313463255*^9}, 3.9115774517786303`*^9, 
   3.911598072636959*^9},ExpressionUUID->"a47c8f13-b925-4c96-96df-\
f35a1d7ebaad"],

Cell[TextData[{
 "There is a sample call for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "=", "0.925"}], TraditionalForm]],
  ExpressionUUID->"e7ffe1f7-8582-4072-92c3-5c9a524b768c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["dim",
     FontSlant->"Italic"], "=", "2"}], TraditionalForm]],ExpressionUUID->
  "70dc4599-f9cb-48db-b1b7-9f7e78195b41"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"gas", " ", "tank"}], "=", "1000"}], TraditionalForm]],
  ExpressionUUID->"1632c666-819d-4df8-8ca5-48afe1095012"],
 ", that usually delivers about 85 percent success rate with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["deathTest",
     FontSlant->"Italic"], "=", 
    StyleBox["True",
     FontSlant->"Italic"]}], TraditionalForm]],ExpressionUUID->
  "24d4e5d1-e72b-4544-9d9c-2bec204eb3c2"],
 ", the default. We must do the rollouts sequentially, rather than in \
parallel, so we can accumulate statistics. A parallel version of statistics \
gathering is planned, but not necessary or and perhaps not possible in a \
nested context in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ". for the main task of this work, finding \[CapitalDelta], but it would be \
helpful for assessing the death tax. We might replace the tail-recursive ",
 StyleBox["For",
  FontSlant->"Italic"],
 " loop with an outer ",
 StyleBox["Fold",
  FontSlant->"Italic"],
 ", but that\[CloseCurlyQuote]s yak-shaving."
}], "Text",
 CellChangeTimes->{{3.775040821033205*^9, 3.775040849084161*^9}, {
   3.77547832904923*^9, 3.775478357225422*^9}, {3.775478393555599*^9, 
   3.775478395135687*^9}, {3.775486859160512*^9, 3.775486862012014*^9}, {
   3.7754879229055443`*^9, 3.775487937038392*^9}, {3.7754879755873327`*^9, 
   3.7754880686839523`*^9}, {3.775488253761981*^9, 3.775488268310772*^9}, {
   3.775488725413525*^9, 3.775488830029674*^9}, {3.775488874078895*^9, 
   3.7754888768254557`*^9}, {3.7754889584691668`*^9, 3.775488961043726*^9}, {
   3.775489290270294*^9, 3.775489373116015*^9}, {3.775489770591716*^9, 
   3.775489801889936*^9}, {3.7761139687072372`*^9, 3.776114025104475*^9}, {
   3.776114059643524*^9, 3.776114135329883*^9}, {3.911577312759233*^9, 
   3.911577313463255*^9}, 3.9115774517786303`*^9, 3.911598073719438*^9, {
   3.911598162435117*^9, 
   3.9115981971859837`*^9}},ExpressionUUID->"cf6e6a87-6fc3-472e-afe5-\
23400995aece"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Do Episode", "Subsection",
 CellChangeTimes->{{3.775491477993228*^9, 
  3.775491484900653*^9}},ExpressionUUID->"120c6ed8-76de-472b-9a85-\
fdd7fbac810b"],

Cell[CellGroupData[{

Cell["Quick Test", "Subsubsection",
 CellChangeTimes->{{3.775497250668038*^9, 
  3.775497259117093*^9}},ExpressionUUID->"fe2e22c6-4a9d-4286-a005-\
710c7f51f011"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "doEpisode", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["doEpisode",
     Background->RGBColor[1, 1, 0]], "[", 
    RowBox[{
    "\[CapitalDelta]_", ",", "maxRol_", ",", "tar_", ",", "tol_", ",", 
     "maxIter_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"irol", ",", 
       RowBox[{"stats", "=", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Found\>\"", "\[Rule]", "zeroStats"}], ",", 
          RowBox[{"\"\<Dead\>\"", "\[Rule]", "zeroStats"}], ",", 
          RowBox[{"\"\<Wandering\>\"", "\[Rule]", "zeroStats"}]}], "|>"}]}]}],
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"irol", "=", "1"}], ",", 
        RowBox[{"irol", "\[LessEqual]", "maxRol"}], ",", 
        RowBox[{"irol", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"With", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"result", "=", 
            RowBox[{
             StyleBox["trial",
              Background->RGBColor[0.87, 0.94, 1]], "[", 
             RowBox[{
             "\[CapitalDelta]", ",", "tar", ",", "tol", ",", "maxIter"}], 
             "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"stats", "@", 
            RowBox[{"result", "@", "\"\<tag\>\""}]}], "=", 
           RowBox[{"cume", "[", 
            RowBox[{
             RowBox[{"stats", "@", 
              RowBox[{"result", "@", "\"\<tag\>\""}]}], ",", 
             RowBox[{"result", "@", "\"\<i\>\""}]}], "]"}]}]}], "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Append", "[", 
       RowBox[{"stats", ",", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<maxRol\>\"", "\[Rule]", "maxRol"}], ",", 
          RowBox[{"\"\<dim\>\"", "\[Rule]", 
           RowBox[{"Length", "@", "tar"}]}], ",", 
          RowBox[{"\"\<tol\>\"", "\[Rule]", "tol"}], ",", 
          RowBox[{"\"\<\[CapitalDelta]\>\"", "\[Rule]", "\[CapitalDelta]"}], ",", 
