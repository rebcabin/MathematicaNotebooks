Cell[TextData[{
 "sets a smaller search radius for the next search (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sigma]", "p"], "\[LeftArrow]", 
     RowBox[{"\[CapitalDelta]", " ", 
      SubscriptBox["\[Sigma]", "p"]}]}], ";", 
    RowBox[{"\[CapitalDelta]", "<", "1"}]}], TraditionalForm]],ExpressionUUID->
  "292cfa5c-f262-4a2a-8231-beb77b2ab565"],
 "); this step explains why \[CapitalDelta] is called ",
 StyleBox["decay",
  FontSlant->"Italic"],
 ": it\[CloseCurlyQuote]s a \[OpenCurlyDoubleQuote]shrinkage factor.\
\[CloseCurlyDoubleQuote]"
}], "ItemNumbered",
