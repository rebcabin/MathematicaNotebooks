Cell[TextData[{
 "starts with two Gaussian guesses, ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "ecf9296c-fd11-4c23-9373-d39799b2cab0"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "d777e534-4a07-4c33-a7b6-410d1c9beae0"],
 ", centered at the current best estimate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "p"], TraditionalForm]],ExpressionUUID->
  "7f078eb8-4322-455c-89ac-eac2b8b92470"],
 " of the target, and within a statistical ",
 StyleBox["search radius",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "p"], TraditionalForm]],ExpressionUUID->
  "01a64cb9-c93c-4fe9-a2df-b2af54350f80"],
 ", the standard deviation of a Gaussian pseudo-random number generator"
}], "ItemNumbered",
