Cell[CellGroupData[{

Cell["Slow Test", "Subsubsection",
 CellChangeTimes->{{3.775497265114189*^9, 
  3.775497268523798*^9}},ExpressionUUID->"c0ec36b9-f4ed-4e52-a730-\
f9ab9ae96ed7"],

Cell[TextData[{
 "Let' s do a deeper test. This takes a few minutes to run, so we don\
\[CloseCurlyQuote]t do it every time the notebook is evaluated. I commented \
out the input cell so that it doesn\[CloseCurlyQuote]t get accidentally \
evaluated. With death test on, we get 29 found and 71 dead, each after about ",
 Cell[BoxData[
  FormBox["20000", TraditionalForm]],ExpressionUUID->
  "3d76a662-8ebe-4023-8dad-78cdd519672f"],
 " judgments. There is plenty of benefit to the death test because it saves \
us about ",
 Cell[BoxData[
  FormBox["80000", TraditionalForm]],ExpressionUUID->
  "bcc854e8-7697-4bdb-a3bf-4a428b240304"],
 " judgments for each failing trial."
}], "Text",
 CellChangeTimes->{{3.775491102665531*^9, 3.775491235910329*^9}, {
  3.775491366647517*^9, 3.775491399351739*^9}, {3.911598289952036*^9, 
  3.911598326955021*^9}},ExpressionUUID->"6bb37c48-e7f0-4f17-8020-\
e2face930b4d"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"doEpisode", "[", 
   RowBox[{
    RowBox[{"\[CapitalDelta]FromLd", "[", 
     RowBox[{"3.", "+", 
      RowBox[{"1.", "/", "16."}]}], "]"}], ",", "100", ",", 
    RowBox[{"getTarget", "@", "200"}], ",", "0.01", ",", "100000"}], "]"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.7754881568467083`*^9, 3.7754882021268272`*^9}, {
  3.775489248081847*^9, 3.775489251028442*^9}, {3.775489675816424*^9, 
  3.7754896761955013`*^9}, {3.775489856523415*^9, 3.775489887736611*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"a366efd9-b845-4382-a32d-b8c1dd64fbd9"],

Cell[TextData[{
 "With death test off, we get nine more successes, but every failure is a \
wanderer that must be followed to the bitter end. This takes almost five \
times longer to run than with death test on. ",
 StyleBox["We deem that the death tax is measurable, but probably worth it to \
save some time. We will miss some searches that will eventually succeed, but \
not enough to make it worth waiting five times longer.",
  Background->RGBColor[1, 0.5, 0.5]],
 " The input cell is commented out, as above, to prevent accidental \
evaluations. Un-comment and evaluate to reproduce our results."
}], "Text",
 CellChangeTimes->{{3.775491244042637*^9, 3.775491340197563*^9}, {
  3.775491414111285*^9, 3.775491456025877*^9}, {3.91159836624054*^9, 
  3.911598415634446*^9}},ExpressionUUID->"b11966f4-20f7-4076-98ed-\
1652a9fa7f24"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"deathTest", "=", "False"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"doEpisode", "[", 
     RowBox[{
      RowBox[{"\[CapitalDelta]FromLd", "[", 
       RowBox[{"3", "+", 
        RowBox[{"1", "/", "16"}]}], "]"}], ",", "100", ",", 
      RowBox[{"getTarget", "@", "200"}], ",", "0.01", ",", "100000"}], 
     "]"}]}], "]"}], "*)"}]], "Input",
 CellChangeTimes->{{3.7754881568467083`*^9, 3.7754882021268272`*^9}, {
  3.775488992947093*^9, 3.775489018105774*^9}, {3.7754900847160587`*^9, 
  3.7754900938711653`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"e6690aee-eddc-4606-bae0-b62fa926c810"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Here\[CloseCurlyQuote]s the Beef", "Chapter",
 CellChangeTimes->{{3.775497286847027*^9, 3.775497291018794*^9}, {
  3.7754973535755053`*^9, 3.775497380113793*^9}, {3.775497472027688*^9, 
  3.775497478978284*^9}, {3.775504442636449*^9, 
  3.775504446198393*^9}},ExpressionUUID->"0fa45a61-39df-458f-9f04-\
adbde5e0f0da"],

Cell[TextData[{
 "Sweep takes a left ",
 StyleBox["ld",
  FontSlant->"Italic"],
 " (number of nines in \[CapitalDelta]), a right ",
 StyleBox["ld",
  FontSlant->"Italic"],
 ", a number ",
 Cell[BoxData[
  FormBox[
   StyleBox["n\[Delta]ld",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "9ac22bfe-3701-4b81-8392-d81b70a1a79f"],
 " of ",
 StyleBox["ld",
  FontSlant->"Italic"],
 "s to sweep, a ",
 StyleBox["maxRol",
  FontSlant->"Italic"],
 ", ",
 StyleBox["target",
  FontSlant->"Italic"],
 ", ",
 "tolerance ",
 StyleBox["tol",
  FontSlant->"Italic"],
 ", and gas tank (",
 StyleBox["maxIter",
  FontSlant->"Italic"],
 "). It does n\[Delta]ld episodes in parallel, one for each \[CapitalDelta] \
implied by the left and right bounds. On my six-core laptop, it definitely \
runs six times faster than without the parallelism. Running this sweep in \
parallel also explains why we can\[CloseCurlyQuote]t run rollouts or \
incremental statistics in parallel: ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " disallows nested parallelism."
}], "Text",
 CellChangeTimes->{{3.7754973933756227`*^9, 3.775497462519185*^9}, {
   3.775497519910919*^9, 3.775497715205872*^9}, 3.9063678654681787`*^9, {
   3.911577879368372*^9, 3.911577904216872*^9}, {3.911598448498015*^9, 
   3.911598454056356*^9}},ExpressionUUID->"e2da88ec-03df-426d-ac15-\
c2d3004bad8c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "pctFound", ",", "pctDead", ",", "pctWandering", ",", "pctFailed", ",", 
     "costOfFinding", ",", "nJudgments"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nJudgments", "[", "episode_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"episode", "[", "\"\<Found\>\"", "]"}], "[", "\"\<n\>\"", "]"}], 
    "+", 
    RowBox[{
     RowBox[{"episode", "[", "\"\<Dead\>\"", "]"}], "[", "\"\<n\>\"", "]"}], "+", 
    RowBox[{
     RowBox[{"episode", "[", "\"\<Wandering\>\"", "]"}], "[", "\"\<n\>\"", 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pctFound", "[", "episode_", "]"}], ":=", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"100.0", " ", 
      RowBox[{
       RowBox[{"episode", "[", "\"\<Found\>\"", "]"}], "[", "\"\<n\>\"", 
       "]"}]}], 
     RowBox[{"nJudgments", "[", "episode", "]"}]], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pctDead", "[", "episode_", "]"}], ":=", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"100.0", 
      RowBox[{
       RowBox[{"episode", "[", "\"\<Dead\>\"", "]"}], "[", "\"\<n\>\"", 
       "]"}]}], 
     RowBox[{"nJudgments", "[", "episode", "]"}]], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pctWandering", "[", "episode_", "]"}], ":=", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"100.0", 
      RowBox[{
       RowBox[{"episode", "[", "\"\<Wandering\>\"", "]"}], "[", "\"\<n\>\"", 
       "]"}]}], 
     RowBox[{"nJudgments", "[", "episode", "]"}]], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pctFailed", "[", "episode_", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{"100.0", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"episode", "[", "\"\<Dead\>\"", "]"}], "[", "\"\<n\>\"", 
        "]"}], "+", 
       RowBox[{
        RowBox[{"episode", "[", "\"\<Wandering\>\"", "]"}], "[", "\"\<n\>\"", 
        "]"}]}], 
      RowBox[{"nJudgments", "[", "episode", "]"}]]}], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"costOfFinding", "[", "episode_", "]"}], ":=", 
    RowBox[{
     RowBox[{"episode", "[", "\"\<Found\>\"", "]"}], "[", "\"\<mean\>\"", 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ClearAll", "[", "sweep", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["sweep",
     Background->RGBColor[1, 1, 0]], "[", 
    RowBox[{
    "lld_", ",", "rld_", ",", "n\[Delta]ld_", ",", "maxRol_", ",", "tar_", ",",
      "tol_", ",", "maxIter_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"ParallelMap", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"echo", "@", 
       RowBox[{
        StyleBox["doEpisode",
         Background->RGBColor[0.87, 0.94, 1]], "[", 
        RowBox[{
         RowBox[{"\[CapitalDelta]FromLd", "@", "#"}], ",", "maxRol", ",", 
         "tar", ",", "tol", ",", "maxIter"}], "]"}]}], "&"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Range", "[", 
      RowBox[{"lld", ",", "rld", ",", 
       FractionBox[
        RowBox[{"rld", "-", "lld"}], "n\[Delta]ld"]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Method", "\[Rule]", "\"\<FinestGrained\>\""}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.774873334591426*^9, 3.774873482157566*^9}, {
   3.7748735145383377`*^9, 3.7748735285625553`*^9}, {3.774875090589366*^9, 
