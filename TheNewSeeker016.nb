        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"le", "++"}], ";", 
           RowBox[{"le", "--"}]}], ")"}], "&"}]}], "]"}], ",", "\"\<    \>\"",
       ",", "\[IndentingNewLine]", 
      RowBox[{"Button", "[", 
       RowBox[{"\"\<  RESET  \>\"", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"le", "=", 
            RowBox[{"-", "2"}]}], ";", 
           RowBox[{"ld", "=", "1.0"}], ";", 
           RowBox[{"lm", "=", "2"}], ";", 
           RowBox[{"r", "=", "2"}], ";", 
           RowBox[{"dim", "=", "2"}]}], ")"}], "&"}]}], "]"}]}], "}"}], "]"}],
    ",", "\[IndentingNewLine]", 
