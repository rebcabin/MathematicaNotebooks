Cell[TextData[{
 "If one instead seeks the ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "de17f847-1e6c-476e-8d14-7a94e1987358"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "f3509114-34f9-4361-843f-8295dc2a86b8"],
 " ",
 StyleBox["design matrices",
  FontSlant->"Italic"],
 ", nearly diagonal in practice, 2,000 dimensions suffice for, say, 1,000 \
degrees of freedom with 1,000 actuators. Searching for ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "df38336c-6deb-4ad6-a5cc-158a24406916"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "bc815ce4-61b3-4876-9cb7-5ab9d82adc78"],
 " has order ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
    "\[LeftDoubleBracketingBar]", "R", "\[RightDoubleBracketingBar]"}], "+", 
    RowBox[{
    "\[LeftDoubleBracketingBar]", "Q", "\[RightDoubleBracketingBar]"}]}], 
   TraditionalForm]],ExpressionUUID->"066cf840-7e78-4686-a654-08e3d5524d67"],
 ", whereas searching for ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "36b76031-68b0-4736-94b8-8a550e863128"],
 " has order ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
    "\[LeftDoubleBracketingBar]", "R", "\[RightDoubleBracketingBar]"}], "\[Times]", 
    RowBox[{
    "\[LeftDoubleBracketingBar]", "Q", "\[RightDoubleBracketingBar]"}]}], 
   TraditionalForm]],ExpressionUUID->"f7273619-585e-403d-afaf-b8ec973b04b3"],
 ". ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "8a97e922-c734-4d8b-9183-968edee736dc"],
 " measures the cost of applying actuators, where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftDoubleBracketingBar]", "R", "\[RightDoubleBracketingBar]"}],
    TraditionalForm]],ExpressionUUID->
  "b6331ba2-014b-44d8-86d3-682e62ef2f23"],
 " is the number of actuators. ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "cfd9b1b8-4f0a-4075-93de-5c2d39b9d137"],
 " measures the cost of missing the mark, where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftDoubleBracketingBar]", "Q", "\[RightDoubleBracketingBar]"}],
    TraditionalForm]],ExpressionUUID->
  "120b602b-c697-4b21-9fd2-99fab25ad87d"],
 " is the number of degrees of freedom. ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "7b089a48-e017-406e-8d2f-29bf99843d2b"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "3fc37679-c7c7-4e5e-b8dc-aa8f9c071247"],
 " imply ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "8e183181-a537-4572-9bdb-7833710afda7"],
 " via the Riccati equation."
}], "Text",
