Cell[TextData[{
 "There follows a function for generating a single, uniform, random ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "f5042f36-c0e1-46a0-b913-435a530c6b2d"],
 "\[NoBreak]-\[NoBreak]vector for a ",
 StyleBox["target",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.775421995769198*^9, 
  3.775422051956843*^9}},ExpressionUUID->"59b5e1cd-a445-49c2-b314-\
d5d72ebdeb84"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "getTarget", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["getTarget",
     Background->RGBColor[1, 1, 0]], "[", 
    RowBox[{"d_", ":", "4"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"uniformInDball", "[", 
     RowBox[{"1", ",", "d"}], "]"}], "\[LeftDoubleBracket]", "1", 
    "\[RightDoubleBracket]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.7744269301270514`*^9, 3.774426960934116*^9}, {
   3.774427040734263*^9, 3.7744270800580883`*^9}, {3.7748305715813293`*^9, 
   3.774830573182324*^9}, 3.775484726092475*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"2b0dfed3-3829-4e2f-a923-bdf260140114"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Seeking", "Chapter",
 CellChangeTimes->{{3.774391722814404*^9, 
  3.7743917240418253`*^9}},ExpressionUUID->"d4c5be86-8ff0-4e7f-b8fb-\
1e88f6d6d7dc"],

Cell[CellGroupData[{

Cell["Bisecting for \[CapitalDelta]", "Section",
 CellChangeTimes->{{3.774859496328145*^9, 3.774859501620225*^9}, {
  3.911574684265836*^9, 
  3.911574688026812*^9}},ExpressionUUID->"006e0ef2-963f-4309-b2c3-\
86680820bb3e"],

Cell[TextData[{
 "For each ",
 StyleBox["dim",
  FontSlant->"Italic"],
 ", ",
 StyleBox["tol",
  FontSlant->"Italic"],
 ", ",
 StyleBox["maxIter;",
  FontSlant->"Italic"],
 " find, via bisection, the smallest decay ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]", TraditionalForm]],ExpressionUUID->
  "e4c04029-fdab-4c9d-baae-55001a39a410"],
 " that converges the most rollouts in an episode, i.e., in the smallest \
number of judgments on the average. Bisection is \
\[OpenCurlyDoubleQuote]divide-and-conquer\[CloseCurlyDoubleQuote] search and \
runs in logarithmic time. However, we must bisect on both \[CapitalDelta] and \
",
 StyleBox["maxIter",
  FontSlant->"Italic"],
 " simultaneously. Our software does not automatically do that, so we bisect \
manually for now, guessing at \[CapitalDelta] and ",
 StyleBox["maxIter",
  FontSlant->"Italic"],
 ", then refining the guesses based on output."
}], "Text",
 CellChangeTimes->CompressedData["
1:eJwdzVtIWnEAx3HXwy5Gc5tSQ8mOZ2HBtgwpYgnRCQOFwXT00ENGRcXC6F5z
6/KQOhu5B7sgNKnBZIvVpkhBBbUGLmyxptRk7qUaI4odHUWE6WT9fz58+Tx+
JXWtDxtSOBxONgkKLZW5Z1kss6PslsEJrq8ANmbq9PCC/VI7DIr7O+BXiecx
3JYGBqG2RDUEE6EzK6yJaRfheGbnCnQ1y9ehkC37AutWO7eg/s5R0mPv8A/Y
12sJJf83ImHokG+cQMPz+SjkUqtxuDE1QMWIHdyBu9BrHSqALvZvEXQsRxWw
p0JaAo2l6ieQn1b1FLpHPC+gR1Rsg6U2gwOmXPvwCmbManb/EaPB13uQflse
