Cell[BoxData[{
 RowBox[{
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sow", "=", "Identity"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ClearAll", "[", "trial", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       StyleBox["trial",
        Background->RGBColor[1, 1, 0]], "[", 
       RowBox[{
       "\[CapitalDelta]_", ",", "tar_", ",", "tol_", ",", "maxIter_"}], "]"}],
       ":=", "\[IndentingNewLine]", 
      RowBox[{"Catch", "[", 
       RowBox[{
        RowBox[{"Catch", "[", 
         RowBox[{
          RowBox[{"Catch", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Fold", "[", 
             RowBox[{
              StyleBox["doJudgment",
               Background->RGBColor[0.87, 0.94, 1]], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"ConstantArray", "[", 
                 RowBox[{"0.", ",", 
                  RowBox[{"Length", "@", "tar"}]}], "]"}], ",", "0.", ",", 
                "1."}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                 "\[CapitalDelta]", ",", "tar", ",", "tol", ",", "maxIter", ",",
                   "i"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "maxIter"}], "}"}]}], "]"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "\"\<Found\>\"", ",", "trialDict"}], "]"}],
           ",", "\"\<Dead\>\"", ",", "trialDict"}], "]"}], 
        ",", "\"\<Wandering\>\"", ",", "trialDict"}], "]"}]}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"trial", "[", 
  RowBox[{".99599", ",", 
   RowBox[{"getTarget", "[", "2", "]"}], ",", "0.01", ",", "1000"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.77488244560742*^9, 3.7748824779511843`*^9}, {
