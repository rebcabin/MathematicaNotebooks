Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["ld", "Code"],
 ", Number of Leading Nines in \[CapitalDelta]"
}], "Subsection",
 CellChangeTimes->{{3.775478770241428*^9, 3.775478775885899*^9}, {
  3.775483943184538*^9, 3.7754839445653467`*^9}, {3.91157072854006*^9, 
  3.911570729292848*^9}, {3.911812900690051*^9, 
  3.911812902714467*^9}},ExpressionUUID->"20a94f80-0d8f-433e-afe4-\
a9a98a29e4e6"],

Cell[TextData[{
 StyleBox["ld", "Code"],
 " is defined as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"-", 
     RowBox[{
      SubscriptBox["log", "10"], "(", 
      RowBox[{"1", "-", "\[CapitalDelta]"}], ")"}]}], ")"}], 
   TraditionalForm]],ExpressionUUID->"8e6ae2ab-ebb3-43c2-affc-cc305d6b27e2"],
 " .It measures the number of leading nines in the decimal expansion of \
\[CapitalDelta]. ld decreases \[LongDash] moves closer to 0 and further from \
1 \[LongDash] as \[CapitalDelta] decreases. We use ",
 StyleBox["ld", "Code"],
 " in the demonstrations for convenience."
}], "Text",
 CellChangeTimes->{{3.775040821033205*^9, 3.775040849084161*^9}, {
   3.77547832904923*^9, 3.775478357225422*^9}, 3.7754783909246607`*^9, {
   3.775478485585718*^9, 3.775478508681756*^9}, {3.775478654839405*^9, 
   3.775478708478166*^9}, {3.77548383648108*^9, 3.7754838481376057`*^9}, {
   3.775483927474001*^9, 3.7754839314214363`*^9}, {3.775561912477562*^9, 
   3.7755619335942907`*^9}, {3.77608038015303*^9, 3.7760804058625107`*^9}, {
   3.7761063733124228`*^9, 3.7761063949625387`*^9}, {3.9115706771450577`*^9, 
   3.911570714785329*^9}, {3.911596649348154*^9, 3.911596658016843*^9}, {
   3.9115967626337023`*^9, 3.911596947519774*^9}, {3.911812886236784*^9, 
   3.911812886588406*^9}},ExpressionUUID->"7921f176-0066-4752-97f9-\
fb81ba0a16c7"],

Cell[TextData[{
 StyleBox["\[CapitalDelta]FromLd",
  FontSlant->"Italic"],
 " and ",
 StyleBox["ldFrom\[CapitalDelta]",
  FontSlant->"Italic"],
 " convert back and forth between \[CapitalDelta] and its number of leading \
nines. "
}], "Text",
 CellChangeTimes->{{3.775040821033205*^9, 3.775040849084161*^9}, {
   3.77547832904923*^9, 3.775478357225422*^9}, 3.7754783909246607`*^9, {
