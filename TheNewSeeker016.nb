   RowBox[{
    RowBox[{"ldFrom\[CapitalDelta]", "@", "0.999915"}], ",", 
    RowBox[{"ldFrom\[CapitalDelta]", "@", "0.999925"}], ",", "16", ",", "100",
     ",", "2000", ",", "0.01", ",", "160000", ",", "Identity"}], "]"}], 
  "*)"}]], "Input",
