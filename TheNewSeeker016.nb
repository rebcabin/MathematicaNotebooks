Cell[TextData[{
 "re-centers the next search at at the closer of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "04e0511b-be48-4f11-ac75-e9a3c86171d6"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "a2107d8e-6677-4726-b3aa-4521b192939e"],
 ": ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "p"], "\[LeftArrow]", "A"}], TraditionalForm]],
  ExpressionUUID->"12edcf38-b78f-492a-9d25-3ebac9343a89"],
 " if ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "a6365443-78a3-4019-8b56-4e9c863547db"],
 " is closer to true target, else ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "p"], "\[LeftArrow]", "B"}], TraditionalForm]],
  ExpressionUUID->"73c0b9db-be49-4e45-ad11-5626cf65441b"]
}], "ItemNumbered",
