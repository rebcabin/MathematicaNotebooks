Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"ldFrom\[CapitalDelta]", ",", "\[CapitalDelta]FromLd"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["ldFrom\[CapitalDelta]",
     Background->RGBColor[1, 1, 0]], "[", "\[CapitalDelta]_", "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{"Log10", "[", 
     RowBox[{"1.", "-", "\[CapitalDelta]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["\[CapitalDelta]FromLd",
     Background->RGBColor[1, 1, 0]], "[", "lm_", "]"}], ":=", 
