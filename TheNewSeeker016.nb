Cell[TextData[{
 "Here is a ",
 StyleBox["trial",
  FontSlant->"Italic"],
 " function that does not ",
 StyleBox["Sow",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.7749160193842373`*^9, 3.774916039208643*^9}, {
