Cell[CellGroupData[{

Cell["Getting Ready: 20 Dimensions", "Section",
 CellChangeTimes->{{3.775505090616858*^9, 3.775505093093402*^9}, {
  3.775505220952448*^9, 
  3.7755052252996397`*^9}},ExpressionUUID->"635ee788-2a7c-4d5a-afec-\
7c2f681fa08d"],

Cell[TextData[{
 "Collect results in a chart. The following runs quickly enough to leave open \
in case of evaluation of the entire notebook.\n\nIt shows that for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["maxIter",
     FontSlant->"Italic"], "=", "1000"}], TraditionalForm]],ExpressionUUID->
  "3e8b1683-e75c-402c-9c5c-b2352c974d8b"],
 " in 20 dimensions. The best \[CapitalDelta] is around 0.9915. There is a \
bit of structure to the chart that needs explaining, and we leave that to the \
future. As expected, when \[CapitalDelta] is too small, runs die, and when \
\[CapitalDelta] is too large, they wander."
}], "Text",
 CellChangeTimes->{{3.7754991119210978`*^9, 3.77549915820688*^9}, {
  3.775499224038888*^9, 3.7754993437094707`*^9}, {3.775504544834673*^9, 
  3.7755045860840273`*^9}},ExpressionUUID->"d5c7dfbd-63d4-4b20-a78f-\
864869496db9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "experiment", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["experiment",
     Background->RGBColor[1, 1, 0]], "[", 
    RowBox[{
    "lld_", ",", "rld_", ",", "n\[Delta]ld_", ",", "maxRol_", ",", "dim_", ",",
      "tol_", ",", "maxIter_", ",", "theEchoer_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"data", "=", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"echo", "=", "theEchoer"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          StyleBox["sweep",
           Background->RGBColor[0.87, 0.94, 1]], "[", 
          RowBox[{"lld", ",", "rld", ",", "n\[Delta]ld", ",", "maxRol", ",", 
           RowBox[{"getTarget", "@", "dim"}], ",", "tol", ",", "maxIter"}], 
          "]"}]}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]s", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", "\"\<\[CapitalDelta]\>\"", "]"}], "&"}], "/@", 
          "data"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\[CapitalDelta]s", ",", 
              RowBox[{"pctFound", "/@", "data"}]}], "}"}], "\[Transpose]"}], ",", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\[CapitalDelta]s", ",", 
              RowBox[{"pctDead", "/@", "data"}]}], "}"}], "\[Transpose]"}], ",", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\[CapitalDelta]s", ",", 
              RowBox[{"pctWandering", "/@", "data"}]}], "}"}], 
            "\[Transpose]"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Frame", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\"\<Percentage\>\"", ",", "\"\<\>\""}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             
             RowBox[{"\"\<\[CapitalDelta] (shrinkage factor for \[Sigma])\>\"",
               ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Seeker versus \[CapitalDelta], dim = \>\"", "<>", 
               RowBox[{"ToString", "[", "dim", "]"}], 
               "<>", "\"\<, # rollouts = \>\"", "<>", 
               RowBox[{"ToString", "[", "maxRol", "]"}], 
               "<>", "\"\<\\ntolerance = \>\"", "<>", 
               RowBox[{"ToString", "[", "tol", "]"}], 
               "<>", "\"\<, # iters/rollout = \>\"", "<>", 
               RowBox[{"ToString", "[", "maxIter", "]"}]}]}], "}"}]}], 
           "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"PlotLegends", "\[Rule]", 
          RowBox[{"{", 
           
           RowBox[{"\"\<% Found\>\"", ",", "\"\<% Dead\>\"", 
            ",", "\"\<% Wandering\>\""}], "}"}]}]}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"experiment", "[", 
  RowBox[{
  "1.875", ",", "2.1875", ",", "16", ",", "100", ",", "20", ",", "0.01", ",", 
   "1000", ",", "Identity"}], "]"}]}], "Input",
 CellChangeTimes->{{3.775072765484158*^9, 3.775072942807266*^9}, {
   3.775072996681199*^9, 3.775073007832778*^9}, {3.775073304743033*^9, 
   3.775073454805215*^9}, {3.7750739216337557`*^9, 3.775073923049692*^9}, {
   3.775075549265931*^9, 3.775075553332511*^9}, 3.775075609142695*^9},
 CellLabel->"In[50]:=",ExpressionUUID->"39b5ca91-3e10-4f7d-8b93-b47d316ff9f8"],

