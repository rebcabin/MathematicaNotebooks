Cell[TextData[{
 "consults an oracle for the Euclidean distance from the true target for each \
of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "eef42919-0f43-4e14-9fba-8cc526ece52f"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "b205d90e-45e9-4824-9137-5625399b9ac2"],
 " (in a real-world setting, the true target is not known; instead, a human \
chooses, subjectively, between the two, and it is this subjective judgment we \
wish to harvest)"
}], "ItemNumbered",
 CellChangeTimes->{{3.775402639959318*^9, 3.77540299308497*^9}, {
