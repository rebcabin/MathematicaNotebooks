Cell[TextData[{
 "Here is an interactive gadget that does not ",
 StyleBox["Sow",
  FontSlant->"Italic"],
 " a visualization",
 ". It runs much more quickly than the visualization and confirms it. We did \
not change the inconsequential call to ",
 StyleBox["Reap",
  FontSlant->"Italic"],
 " for fear of breaking the code."
}], "Text",
 CellChangeTimes->{{3.775422758812628*^9, 3.7754228207121162`*^9}, {
   3.775486778595716*^9, 3.775486785795486*^9}, {3.775487281709807*^9, 
